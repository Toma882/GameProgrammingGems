<Window x:Class="GPGems.DemoApp.FsmDemoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:f="clr-namespace:GPGems.Visualization.FSM;assembly=GPGems.Visualization"
        mc:Ignorable="d"
        Title="有限状态机 FSM - NPC AI 演示" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#16213e">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧控制面板 -->
        <Border Grid.Column="0" Background="#0f3460" Margin="5" Padding="15" CornerRadius="5">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="🎮 NPC AI" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0 0 0 15"/>

                    <!-- NPC 状态 -->
                    <GroupBox Header="NPC 状态" BorderBrush="#533483" Foreground="White" Margin="0 0 0 10">
                        <StackPanel Margin="5">
                            <TextBlock x:Name="CurrentStateText" Text="当前状态: 巡逻" Foreground="#4ecca3" FontSize="14" FontWeight="Bold"/>
                            <TextBlock x:Name="NpcHealthText" Text="生命值: 100" Foreground="White" Margin="0 5 0 0"/>
                            <TextBlock x:Name="TargetHealthText" Text="目标生命值: 100" Foreground="White" Margin="0 5 0 0"/>
                            <TextBlock x:Name="DistanceText" Text="距离: 0" Foreground="White" Margin="0 5 0 0"/>
                        </StackPanel>
                    </GroupBox>

                    <!-- 控制按钮 -->
                    <StackPanel Orientation="Horizontal" Margin="0 10 0 10">
                        <Button x:Name="ResetBtn" Content="🔄 重置" Click="OnReset"
                                Padding="10 5" Margin="0 0 5 0"
                                Background="#e94560" Foreground="White" BorderThickness="0"/>
                        <Button x:Name="PauseBtn" Content="⏸️ 暂停" Click="OnPause"
                                Padding="10 5"
                                Background="#0f3460" Foreground="White" BorderBrush="White" BorderThickness="1"/>
                    </StackPanel>

                    <!-- 模拟速度 -->
                    <TextBlock Foreground="#a0a0a0" Margin="0 10 0 5">模拟速度</TextBlock>
                    <DockPanel>
                        <Slider x:Name="SpeedSlider" Minimum="0.1" Maximum="3" Value="1"
                                TickFrequency="0.1"
                                DockPanel.Dock="Left" Width="150"
                                ValueChanged="OnSpeedChanged"/>
                        <TextBlock x:Name="SpeedText" Text="1.0x" Foreground="White"
                                   VerticalAlignment="Center" Margin="10 0 0 0" MinWidth="30"/>
                    </DockPanel>

                    <Separator Margin="0 15" Background="#533483"/>

                    <TextBlock Text="📖 状态转换" Foreground="White" FontSize="14" FontWeight="Bold" Margin="0 5"/>

                    <TextBlock Foreground="#a0a0a0" Margin="0 5" TextWrapping="Wrap">
                        <Run Foreground="#4ecca3">🔵 巡逻</Run>
                        <LineBreak/>
                        NPC 在区域内随机移动
                    </TextBlock>
                    <TextBlock Foreground="#a0a0a0" Margin="0 5" TextWrapping="Wrap">
                        <Run Foreground="#e94560">🔴 追击</Run>
                        <LineBreak/>
                        发现目标进入感知范围
                    </TextBlock>
                    <TextBlock Foreground="#a0a0a0" Margin="0 5" TextWrapping="Wrap">
                        <Run Foreground="#ffd700">🟡 攻击</Run>
                        <LineBreak/>
                        目标进入攻击范围
                    </TextBlock>
                    <TextBlock Foreground="#a0a0a0" Margin="0 5" TextWrapping="Wrap">
                        <Run Foreground="#808080">⚫ 死亡</Run>
                        <LineBreak/>
                        生命值降为0
                    </TextBlock>

                    <Separator Margin="0 15" Background="#533483"/>

                    <TextBlock Text="ℹ️ 说明" Foreground="White" FontSize="12" FontWeight="Bold" Margin="0 5"/>
                    <TextBlock Foreground="#a0a0a0" FontSize="11" TextWrapping="Wrap">
                        右侧显示 NPC 状态机的实时转换。
                        红色节点为当前活动状态，
                        绿色箭头表示状态转换条件。
                    </TextBlock>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- 右侧可视化区域 -->
        <Grid Grid.Column="1" Margin="5">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="200"/>
            </Grid.RowDefinitions>

            <!-- FSM 状态图 -->
            <Border Grid.Row="0" Background="#0a192f" CornerRadius="5" Margin="0 0 0 5">
                <Grid>
                    <TextBlock Text="📊 状态转换图" Foreground="White" FontSize="14" FontWeight="Bold"
                               HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10"/>
                    <f:FsmCanvas x:Name="FsmCanvas" Margin="10 40 10 10"/>
                </Grid>
            </Border>

            <!-- 2D 场景可视化 -->
            <Border Grid.Row="1" Background="#0a192f" CornerRadius="5">
                <Grid>
                    <TextBlock Text="🎯 战斗场景" Foreground="White" FontSize="14" FontWeight="Bold"
                               HorizontalAlignment="Left" VerticalAlignment="Top" Margin="10"/>
                    <Canvas x:Name="SceneCanvas" Margin="10 40 10 10" Background="#16213e"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
