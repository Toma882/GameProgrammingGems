<Window x:Class="GPGems.DemoApp.AI.NearestNeighborBenchmarkWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="最近邻算法性能对比 - Game Programming Gems"
        Height="750" Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="#0f0f23">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 顶部标题 -->
        <Border Grid.Row="0" Background="#1a1a2e" Padding="15">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="⚡ 最近邻算法性能基准测试" FontSize="18" Foreground="White" FontWeight="Bold"/>
                <TextBlock Text="暴力搜索 vs KD树 vs Ball树 vs LSH 局部敏感哈希" FontSize="12" Foreground="#a0a0a0" Margin="20,5,0,0"/>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：参数控制 -->
            <Border Grid.Column="0" Background="#1a1a2e" Margin="5" Padding="12" CornerRadius="8">
                <ScrollViewer>
                    <StackPanel>
                        <TextBlock Text="📊 测试参数" FontSize="14" Foreground="White" FontWeight="Bold" Margin="0 0 0 10"/>

                        <!-- 数据规模 -->
                        <TextBlock Text="数据点数量" Foreground="#a0a0a0" FontSize="11" Margin="0 8 0 2"/>
                        <Slider x:Name="PointCountSlider" Minimum="100" Maximum="50000" Value="5000" TickFrequency="1000" IsSnapToTickEnabled="True" Foreground="#e67e22"/>
                        <TextBlock x:Name="PointCountText" Text="5000" Foreground="#e67e22" FontSize="14" FontWeight="Bold" HorizontalAlignment="Right"/>

                        <!-- 维度 -->
                        <TextBlock Text="特征维度" Foreground="#a0a0a0" FontSize="11" Margin="0 15 0 2"/>
                        <Slider x:Name="DimensionSlider" Minimum="2" Maximum="128" Value="16" TickFrequency="1" IsSnapToTickEnabled="True" Foreground="#e67e22"/>
                        <TextBlock x:Name="DimensionText" Text="16" Foreground="#e67e22" FontSize="14" FontWeight="Bold" HorizontalAlignment="Right"/>

                        <!-- k值 -->
                        <TextBlock Text="k值（近邻数量）" Foreground="#a0a0a0" FontSize="11" Margin="0 15 0 2"/>
                        <Slider x:Name="KValueSlider" Minimum="1" Maximum="100" Value="10" TickFrequency="1" IsSnapToTickEnabled="True" Foreground="#e67e22"/>
                        <TextBlock x:Name="KValueText" Text="10" Foreground="#e67e22" FontSize="14" FontWeight="Bold" HorizontalAlignment="Right"/>

                        <!-- 查询次数 -->
                        <TextBlock Text="查询次数" Foreground="#a0a0a0" FontSize="11" Margin="0 15 0 2"/>
                        <Slider x:Name="QueryCountSlider" Minimum="10" Maximum="1000" Value="100" TickFrequency="10" IsSnapToTickEnabled="True" Foreground="#e67e22"/>
                        <TextBlock x:Name="QueryCountText" Text="100" Foreground="#e67e22" FontSize="14" FontWeight="Bold" HorizontalAlignment="Right"/>

                        <!-- 算法选择 -->
                        <TextBlock Text="算法选择" FontSize="12" Foreground="White" FontWeight="Bold" Margin="0 15 0 8"/>
                        <CheckBox x:Name="UseBruteForce" Content="暴力搜索（BruteForce）" IsChecked="True" Foreground="White" Margin="0 3"/>
                        <CheckBox x:Name="UseKDTree" Content="KD树" IsChecked="True" Foreground="White" Margin="0 3"/>
                        <CheckBox x:Name="UseBallTree" Content="Ball树" IsChecked="True" Foreground="White" Margin="0 3"/>
                        <CheckBox x:Name="UseLSH" Content="LSH 局部敏感哈希" IsChecked="True" Foreground="White" Margin="0 3"/>

                        <Separator Background="#333" Margin="0 15"/>

                        <!-- 运行按钮 -->
                        <Button x:Name="RunBenchmarkBtn" Content="🚀 运行基准测试" Background="#3498db" Foreground="White" FontWeight="Bold" Padding="10" Margin="0 5" Click="RunBenchmark_Click"/>
                        <Button x:Name="RunAnimationBtn" Content="📈 维度/规模 扫描动画" Background="#9b59b6" Foreground="White" FontWeight="Bold" Padding="10" Margin="0 5" Click="RunAnimation_Click"/>

                        <Separator Background="#333" Margin="0 15"/>

                        <!-- 算法说明 -->
                        <TextBlock Text="💡 算法适用场景" FontSize="12" Foreground="White" FontWeight="Bold" Margin="0 0 0 8"/>
                        <TextBlock TextWrapping="Wrap" Foreground="#888" FontSize="10" LineHeight="18">
                            <Run Foreground="#e74c3c">暴力搜索：</Run><Run>数据量小(&lt;1000)，精确</Run><LineBreak/>
                            <Run Foreground="#3498db">KD树：</Run><Run>低维数据(&lt;20维)，精确</Run><LineBreak/>
                            <Run Foreground="#2ecc71">Ball树：</Run><Run>高维数据，精确，最稳健</Run><LineBreak/>
                            <Run Foreground="#f39c12">LSH哈希：</Run><Run>超大规模(&gt;10万)，近似</Run>
                        </TextBlock>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- 右侧：结果展示 -->
            <Border Grid.Column="1" Background="#0a0a1a" Margin="5 5 5 0" CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- 图表区域 -->
                    <Border Grid.Row="0" Background="#16213e" Margin="5" Padding="10" CornerRadius="8" Height="300" VerticalAlignment="Top">
                        <TextBlock Text="📊 性能对比图表区域" Foreground="#a0a0a0" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <!-- 详细结果表格 -->
                    <ScrollViewer Grid.Row="1" Margin="5">
                        <ItemsControl x:Name="ResultsPanel">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- 底部日志 -->
        <Border Grid.Row="2" Background="#0a0a1a" Margin="5 0 5 5" Padding="8" CornerRadius="8">
            <ScrollViewer MaxHeight="80">
                <TextBlock x:Name="LogText" Foreground="#e67e22" FontFamily="Consolas" FontSize="10"/>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
