<Window x:Class="GPGems.DemoApp.AI.NearestNeighborSearchDemoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="最近邻搜索多算法对比演示 - Game Programming Gems"
        Height="800" Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="#16213e">

    <Window.Resources>
        <Style x:Key="AlgorithmButtonStyle" TargetType="RadioButton">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Border" Background="{TemplateBinding Background}"
                                CornerRadius="4" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Border" Property="Background" Value="#e94560"/>
                                <Setter Property="FontWeight" Value="Bold"/>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter TargetName="Border" Property="Background" Value="#533483"/>
                                <Setter Property="FontWeight" Value="Normal"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部算法选择栏 -->
        <Border Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2"
                Background="#0f3460" Margin="5 5 5 0" Padding="15" CornerRadius="5">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="🔬 搜索算法: " Foreground="White" FontSize="14" FontWeight="Bold"
                           VerticalAlignment="Center" Margin="0 0 15 0"/>

                <RadioButton x:Name="AlgoBruteForce" Content="暴力搜索" Foreground="White"
                             Checked="OnAlgorithmChanged" Margin="0 0 15 0"
                             FontSize="12" FontWeight="Bold" IsChecked="True" Background="#e94560" Padding="12 4"
                             Style="{StaticResource AlgorithmButtonStyle}"/>

                <RadioButton x:Name="AlgoKDTree" Content="KD树" Foreground="White"
                             Checked="OnAlgorithmChanged" Margin="0 0 15 0"
                             FontSize="12" Background="#533483" Padding="12 4"
                             Style="{StaticResource AlgorithmButtonStyle}"/>

                <RadioButton x:Name="AlgoBallTree" Content="Ball树" Foreground="White"
                             Checked="OnAlgorithmChanged" Margin="0 0 15 0"
                             FontSize="12" Background="#533483" Padding="12 4"
                             Style="{StaticResource AlgorithmButtonStyle}"/>

                <RadioButton x:Name="AlgoLSH" Content="LSH 局部敏感哈希" Foreground="White"
                             Checked="OnAlgorithmChanged" Margin="0 0 15 0"
                             FontSize="12" Background="#533483" Padding="12 4"
                             Style="{StaticResource AlgorithmButtonStyle}"/>

                <RadioButton x:Name="AlgoAll" Content="🔄 全部对比" Foreground="White"
                             Checked="OnAlgorithmChanged" Margin="0 0 15 0"
                             FontSize="12" FontWeight="Bold" Background="#28a745" Padding="12 4"
                             Style="{StaticResource AlgorithmButtonStyle}"/>

                <TextBlock x:Name="AlgorithmDescText" Text="O(N) 线性扫描，精确但慢"
                           Foreground="#a0a0a0" FontSize="11" Margin="20 0 0 0"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- 左侧控制面板 -->
        <Border Grid.Row="1" Grid.Column="0" Background="#0f3460" Margin="5" Padding="15" CornerRadius="5">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="🔍 搜索设置" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0 0 0 15"/>

                    <!-- 数据点数量 -->
                    <TextBlock Foreground="#a0a0a0" Margin="0 10 0 5">数据点数量</TextBlock>
                    <DockPanel>
                        <Slider x:Name="PointCountSlider" Minimum="100" Maximum="10000" Value="1000"
                                TickFrequency="100" IsSnapToTickEnabled="True"
                                DockPanel.Dock="Left" Width="150"
                                ValueChanged="OnSettingsChanged"/>
                        <TextBlock x:Name="PointCountText" Text="1000" Foreground="White"
                                   VerticalAlignment="Center" Margin="10 0 0 0" MinWidth="40"/>
                    </DockPanel>

                    <!-- 维度 -->
                    <TextBlock Foreground="#a0a0a0" Margin="0 15 0 5">特征维度</TextBlock>
                    <DockPanel>
                        <Slider x:Name="DimensionSlider" Minimum="2" Maximum="128" Value="8"
                                TickFrequency="2" IsSnapToTickEnabled="True"
                                DockPanel.Dock="Left" Width="150"
                                ValueChanged="OnSettingsChanged"/>
                        <TextBlock x:Name="DimensionText" Text="8" Foreground="White"
                                   VerticalAlignment="Center" Margin="10 0 0 0" MinWidth="40"/>
                    </DockPanel>

                    <!-- k值 -->
                    <TextBlock Foreground="#a0a0a0" Margin="0 15 0 5">近邻数量 k</TextBlock>
                    <DockPanel>
                        <Slider x:Name="KValueSlider" Minimum="1" Maximum="100" Value="10"
                                TickFrequency="1" IsSnapToTickEnabled="True"
                                DockPanel.Dock="Left" Width="150"
                                ValueChanged="OnSettingsChanged"/>
                        <TextBlock x:Name="KValueText" Text="10" Foreground="White"
                                   VerticalAlignment="Center" Margin="10 0 0 0" MinWidth="40"/>
                    </DockPanel>

                    <!-- 搜索半径 -->
                    <TextBlock Foreground="#a0a0a0" Margin="0 15 0 5">搜索半径</TextBlock>
                    <DockPanel>
                        <Slider x:Name="RadiusSlider" Minimum="5" Maximum="50" Value="20"
                                TickFrequency="1" IsSnapToTickEnabled="True"
                                DockPanel.Dock="Left" Width="150"
                                ValueChanged="OnSettingsChanged"/>
                        <TextBlock x:Name="RadiusText" Text="20" Foreground="White"
                                   VerticalAlignment="Center" Margin="10 0 0 0" MinWidth="40"/>
                    </DockPanel>

                    <!-- 操作按钮 -->
                    <StackPanel Orientation="Horizontal" Margin="0 20 0 10">
                        <Button x:Name="RegenerateBtn" Content="🎲 重新生成" Click="OnRegenerate"
                                Padding="10 5" Margin="0 0 5 0"
                                Background="#e94560" Foreground="White" BorderThickness="0"/>
                        <Button x:Name="ClearSearchBtn" Content="🗑️ 清除搜索" Click="OnClearSearch"
                                Padding="10 5"
                                Background="#0f3460" Foreground="White" BorderBrush="White" BorderThickness="1"/>
                    </StackPanel>

                    <Separator Margin="0 15" Background="#533483"/>

                    <!-- 搜索统计 -->
                    <GroupBox Header="📊 搜索统计" BorderBrush="#533483" Foreground="White" Margin="0 0 0 10">
                        <StackPanel Margin="5">
                            <TextBlock x:Name="AlgorithmNameText" Text="当前算法: 暴力搜索" Foreground="White" FontWeight="Bold"/>
                            <TextBlock x:Name="BuildTimeText" Text="构建时间: 0.00 ms" Foreground="White" Margin="0 3 0 0"/>
                            <TextBlock x:Name="SearchTimeText" Text="搜索时间: 0.00 μs" Foreground="White" Margin="0 3 0 0"/>
                            <TextBlock x:Name="FoundCountText" Text="找到邻居: 0" Foreground="White" Margin="0 3 0 0"/>
                            <TextBlock x:Name="AvgDistanceText" Text="平均距离: 0.00" Foreground="White" Margin="0 3 0 0"/>
                            <TextBlock x:Name="AccuracyText" Text="相对精度: 100%" Foreground="#4ecca3" Margin="0 5 0 0"/>
                        </StackPanel>
                    </GroupBox>

                    <Separator Margin="0 15" Background="#533483"/>

                    <!-- 图例 -->
                    <TextBlock Text="🎨 图例" Foreground="White" FontSize="14" FontWeight="Bold" Margin="0 5"/>

                    <StackPanel Margin="5 0">
                        <DockPanel Margin="0 3">
                            <Ellipse Width="16" Height="16" Fill="#4ecca3" Margin="0 0 5 0"/>
                            <TextBlock Text="数据点" Foreground="White"/>
                        </DockPanel>
                        <DockPanel Margin="0 3">
                            <Ellipse Width="16" Height="16" Fill="#e94560" Margin="0 0 5 0"/>
                            <TextBlock Text="查询点" Foreground="White"/>
                        </DockPanel>
                        <DockPanel Margin="0 3">
                            <Ellipse Width="16" Height="16" Fill="#ffc107" Margin="0 0 5 0"/>
                            <TextBlock Text="k个最近邻" Foreground="White"/>
                        </DockPanel>
                        <DockPanel Margin="0 3">
                            <Ellipse Width="16" Height="16" Stroke="#4361ee" StrokeThickness="2" Margin="0 0 5 0"/>
                            <TextBlock Text="搜索半径" Foreground="White"/>
                        </DockPanel>
                    </StackPanel>

                    <Separator Margin="0 15" Background="#533483"/>

                    <!-- 操作说明 -->
                    <TextBlock Text="ℹ️ 说明" Foreground="White" FontSize="12" FontWeight="Bold" Margin="0 5"/>
                    <TextBlock Foreground="#a0a0a0" FontSize="11" TextWrapping="Wrap">
                        在画布上点击设置查询点，观察不同算法的搜索过程。
                        选择「全部对比」模式查看各算法的性能差异和精度对比。
                    </TextBlock>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- 右侧可视化区域 -->
        <Border Grid.Row="1" Grid.Column="1" Margin="5" Background="#0a192f" CornerRadius="5">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 标题 -->
                <TextBlock x:Name="TitleText" Text="最近邻搜索可视化" Foreground="White"
                           FontSize="16" FontWeight="Bold"
                           HorizontalAlignment="Left" VerticalAlignment="Top" Margin="15,10,0,0"/>

                <!-- 搜索画布 -->
                <Canvas x:Name="SearchCanvas" Grid.Row="1" Margin="15,50,15,15"
                        Background="#0d0d20" MouseLeftButtonDown="OnCanvasClick"/>
            </Grid>
        </Border>
    </Grid>
</Window>
