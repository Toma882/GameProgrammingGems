<Window x:Class="GPGems.DemoApp.SteeringDemoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:s="clr-namespace:GPGems.Visualization.Steering;assembly=GPGems.Visualization"
        mc:Ignorable="d"
        Title="Steering 定向行为" Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        Background="#16213e">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧控制面板 -->
        <Border Grid.Column="0" Background="#0f3460" Margin="5" Padding="15" CornerRadius="5">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="🎯 定向行为" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0 0 0 15"/>

                    <!-- 行为选择 -->
                    <TextBlock Foreground="#a0a0a0" Margin="0 10 0 5">选择行为</TextBlock>
                    <RadioButton Content="Seek - 追逐" Foreground="White"
                                 GroupName="Behavior" IsChecked="True"
                                 Checked="OnBehaviorChanged" Margin="0 3"/>
                    <RadioButton Content="Flee - 逃离" Foreground="White"
                                 GroupName="Behavior"
                                 Checked="OnBehaviorChanged" Margin="0 3"/>
                    <RadioButton Content="Arrive - 到达" Foreground="White"
                                 GroupName="Behavior"
                                 Checked="OnBehaviorChanged" Margin="0 3"/>
                    <RadioButton Content="Wander - 漫游" Foreground="White"
                                 GroupName="Behavior"
                                 Checked="OnBehaviorChanged" Margin="0 3"/>
                    <RadioButton Content="Pursue - 追击" Foreground="White"
                                 GroupName="Behavior"
                                 Checked="OnBehaviorChanged" Margin="0 3"/>
                    <RadioButton Content="Evade - 躲避" Foreground="White"
                                 GroupName="Behavior"
                                 Checked="OnBehaviorChanged" Margin="0 3"/>

                    <!-- 参数调节 -->
                    <Separator Margin="0 20" Background="#533483"/>
                    <TextBlock Foreground="#a0a0a0" Margin="0 10 0 5">最大速度</TextBlock>
                    <DockPanel>
                        <Slider x:Name="SpeedSlider" Minimum="1" Maximum="10" Value="3"
                                DockPanel.Dock="Left" Width="120"
                                ValueChanged="OnSpeedChanged"/>
                        <TextBlock x:Name="SpeedText" Text="3" Foreground="White"
                                   VerticalAlignment="Center" Margin="10 0 0 0"/>
                    </DockPanel>

                    <TextBlock Foreground="#a0a0a0" Margin="0 10 0 5">转向力</TextBlock>
                    <DockPanel>
                        <Slider x:Name="ForceSlider" Minimum="0.05" Maximum="0.5" Value="0.15"
                                DockPanel.Dock="Left" Width="120"
                                ValueChanged="OnForceChanged"/>
                        <TextBlock x:Name="ForceText" Text="0.15" Foreground="White"
                                   VerticalAlignment="Center" Margin="10 0 0 0"/>
                    </DockPanel>

                    <!-- 控制按钮 -->
                    <StackPanel Margin="0 20 0 0">
                        <Button x:Name="ResetBtn" Content="🔄 重置位置" Click="OnReset"
                                Padding="10 8" Margin="0 0 0 5"
                                Background="#e94560" Foreground="White" BorderThickness="0"/>
                        <Button x:Name="ClearTrailBtn" Content="🧹 清除轨迹" Click="OnClearTrail"
                                Padding="10 8"
                                Background="#4ecca3" Foreground="White" BorderThickness="0"/>
                    </StackPanel>

                    <Separator Margin="0 20" Background="#533483"/>

                    <!-- 说明 -->
                    <TextBlock Text="ℹ️ 操作说明" Foreground="White" FontSize="12" FontWeight="Bold" Margin="0 5"/>
                    <TextBlock Foreground="#a0a0a0" FontSize="11" TextWrapping="Wrap" Margin="0 5">
                        点击画布设置目标位置。
                        <LineBreak/>
                        <Run Foreground="LimeGreen">● 绿色</Run> = 智能体
                        <LineBreak/>
                        <Run Foreground="Yellow">○ 黄圈</Run> = 目标点
                        <LineBreak/>
                        <Run Foreground="DodgerBlue">● 蓝色</Run> = 移动目标（Pursue/Evade）
                    </TextBlock>

                    <Separator Margin="0 20" Background="#533483"/>

                    <TextBlock Text="📖 行为对比" Foreground="White" FontSize="12" FontWeight="Bold" Margin="0 5"/>
                    <TextBlock Foreground="#a0a0a0" FontSize="11" TextWrapping="Wrap">
                        <Run Foreground="White">Seek vs Pursue:</Run>
                        <LineBreak/>
                        Seek 直接朝向目标当前位置；
                        Pursue 预测目标未来位置，轨迹更自然。
                        <LineBreak/><LineBreak/>
                        <Run Foreground="White">Arrive vs Seek:</Run>
                        <LineBreak/>
                        Arrive 在接近目标时减速，实现平滑停止。
                    </TextBlock>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- 右侧可视化区域 -->
        <s:SteeringCanvas x:Name="SteeringCanvas" Grid.Column="1" Margin="5"/>
    </Grid>
</Window>
