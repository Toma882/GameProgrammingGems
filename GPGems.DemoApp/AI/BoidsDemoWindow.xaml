<Window x:Class="GPGems.DemoApp.BoidsDemoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:b="clr-namespace:GPGems.Visualization.Boids;assembly=GPGems.Visualization"
        mc:Ignorable="d"
        Title="Boids 群体行为 - Reynolds 算法" Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#16213e">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧控制面板 -->
        <Border Grid.Column="0" Background="#0f3460" Margin="5" Padding="15" CornerRadius="5">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <TextBlock Text="🎛️ 控制" Foreground="White" FontSize="16" FontWeight="Bold" Margin="0 0 0 15"/>

                    <!-- 群体大小 -->
                    <TextBlock Foreground="#a0a0a0" Margin="0 10 0 5">群体大小</TextBlock>
                    <DockPanel>
                        <Slider x:Name="BoidCountSlider" Minimum="10" Maximum="500" Value="50"
                                TickFrequency="10" IsSnapToTickEnabled="True"
                                DockPanel.Dock="Left" Width="150"
                                ValueChanged="OnBoidCountChanged"/>
                        <TextBlock x:Name="BoidCountText" Text="50" Foreground="White"
                                   VerticalAlignment="Center" Margin="10 0 0 0" MinWidth="30"/>
                    </DockPanel>

                    <!-- 感知范围 -->
                    <TextBlock Foreground="#a0a0a0" Margin="0 10 0 5">感知范围</TextBlock>
                    <DockPanel>
                        <Slider x:Name="PerceptionSlider" Minimum="10" Maximum="100" Value="25"
                                TickFrequency="5"
                                DockPanel.Dock="Left" Width="150"
                                ValueChanged="OnSettingChanged"/>
                        <TextBlock x:Name="PerceptionText" Text="25" Foreground="White"
                                   VerticalAlignment="Center" Margin="10 0 0 0" MinWidth="30"/>
                    </DockPanel>

                    <!-- 分离距离 -->
                    <TextBlock Foreground="#a0a0a0" Margin="0 10 0 5">分离距离</TextBlock>
                    <DockPanel>
                        <Slider x:Name="SeparationSlider" Minimum="5" Maximum="50" Value="10"
                                TickFrequency="1"
                                DockPanel.Dock="Left" Width="150"
                                ValueChanged="OnSettingChanged"/>
                        <TextBlock x:Name="SeparationText" Text="10" Foreground="White"
                                   VerticalAlignment="Center" Margin="10 0 0 0" MinWidth="30"/>
                    </DockPanel>

                    <!-- 期望速度 -->
                    <TextBlock Foreground="#a0a0a0" Margin="0 10 0 5">期望速度</TextBlock>
                    <DockPanel>
                        <Slider x:Name="DesiredSpeedSlider" Minimum="1" Maximum="10" Value="2"
                                TickFrequency="0.5"
                                DockPanel.Dock="Left" Width="150"
                                ValueChanged="OnSettingChanged"/>
                        <TextBlock x:Name="DesiredSpeedText" Text="2" Foreground="White"
                                   VerticalAlignment="Center" Margin="10 0 0 0" MinWidth="30"/>
                    </DockPanel>

                    <!-- 最大速度 -->
                    <TextBlock Foreground="#a0a0a0" Margin="0 10 0 5">最大速度</TextBlock>
                    <DockPanel>
                        <Slider x:Name="MaxSpeedSlider" Minimum="2" Maximum="20" Value="4"
                                TickFrequency="1"
                                DockPanel.Dock="Left" Width="150"
                                ValueChanged="OnSettingChanged"/>
                        <TextBlock x:Name="MaxSpeedText" Text="4" Foreground="White"
                                   VerticalAlignment="Center" Margin="10 0 0 0" MinWidth="30"/>
                    </DockPanel>

                    <!-- 分离权重 -->
                    <TextBlock Foreground="#a0a0a0" Margin="0 10 0 5">分离权重</TextBlock>
                    <DockPanel>
                        <Slider x:Name="SepWeightSlider" Minimum="0" Maximum="5" Value="1.5"
                                TickFrequency="0.1"
                                DockPanel.Dock="Left" Width="150"
                                ValueChanged="OnSettingChanged"/>
                        <TextBlock x:Name="SepWeightText" Text="1.5" Foreground="White"
                                   VerticalAlignment="Center" Margin="10 0 0 0" MinWidth="30"/>
                    </DockPanel>

                    <!-- 对齐权重 -->
                    <TextBlock Foreground="#a0a0a0" Margin="0 10 0 5">对齐权重</TextBlock>
                    <DockPanel>
                        <Slider x:Name="AliWeightSlider" Minimum="0" Maximum="5" Value="1.0"
                                TickFrequency="0.1"
                                DockPanel.Dock="Left" Width="150"
                                ValueChanged="OnSettingChanged"/>
                        <TextBlock x:Name="AliWeightText" Text="1.0" Foreground="White"
                                   VerticalAlignment="Center" Margin="10 0 0 0" MinWidth="30"/>
                    </DockPanel>

                    <!-- 凝聚权重 -->
                    <TextBlock Foreground="#a0a0a0" Margin="0 10 0 5">凝聚权重</TextBlock>
                    <DockPanel>
                        <Slider x:Name="CohWeightSlider" Minimum="0" Maximum="5" Value="1.0"
                                TickFrequency="0.1"
                                DockPanel.Dock="Left" Width="150"
                                ValueChanged="OnSettingChanged"/>
                        <TextBlock x:Name="CohWeightText" Text="1.0" Foreground="White"
                                   VerticalAlignment="Center" Margin="10 0 0 0" MinWidth="30"/>
                    </DockPanel>

                    <!-- 时间缩放 -->
                    <TextBlock Foreground="#a0a0a0" Margin="0 10 0 5">时间缩放</TextBlock>
                    <DockPanel>
                        <Slider x:Name="TimeScaleSlider" Minimum="0.1" Maximum="2" Value="0.5"
                                TickFrequency="0.1"
                                DockPanel.Dock="Left" Width="150"
                                ValueChanged="OnTimeScaleChanged"/>
                        <TextBlock x:Name="TimeScaleText" Text="0.5" Foreground="White"
                                   VerticalAlignment="Center" Margin="10 0 0 0" MinWidth="30"/>
                    </DockPanel>

                    <!-- 控制按钮 -->
                    <StackPanel Orientation="Horizontal" Margin="0 20 0 10">
                        <Button x:Name="ResetBtn" Content="🔄 重置" Click="OnReset"
                                Padding="10 5" Margin="0 0 5 0"
                                Background="#e94560" Foreground="White" BorderThickness="0"/>
                        <Button x:Name="PauseBtn" Content="⏸️ 暂停" Click="OnPause"
                                Padding="10 5"
                                Background="#0f3460" Foreground="White" BorderBrush="White" BorderThickness="1"/>
                    </StackPanel>

                    <Separator Margin="0 10" Background="#533483"/>

                    <TextBlock Text="📖 三大规则" Foreground="White" FontSize="14" FontWeight="Bold" Margin="0 5"/>

                    <TextBlock Foreground="#a0a0a0" Margin="0 5" TextWrapping="Wrap">
                        <Run Foreground="#e94560">1. 分离</Run>: 与邻近个体保持距离，避免碰撞
                    </TextBlock>
                    <TextBlock Foreground="#a0a0a0" Margin="0 5" TextWrapping="Wrap">
                        <Run Foreground="#4ecca3">2. 对齐</Run>: 与邻近个体保持相同方向
                    </TextBlock>
                    <TextBlock Foreground="#a0a0a0" Margin="0 5" TextWrapping="Wrap">
                        <Run Foreground="#e94560">3. 凝聚</Run>: 向邻近个体的质心靠拢
                    </TextBlock>

                    <Separator Margin="0 10" Background="#533483"/>

                    <TextBlock Text="ℹ️ 说明" Foreground="White" FontSize="12" FontWeight="Bold" Margin="0 5"/>
                    <TextBlock Foreground="#a0a0a0" FontSize="11" TextWrapping="Wrap">
                        调节左侧参数观察群体行为的变化。
                        增大感知范围会让群体更连贯，
                        增加分离距离会让个体更分散。
                    </TextBlock>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- 右侧可视化区域 -->
        <b:BoidsCanvas x:Name="BoidsCanvas" Grid.Column="1" Margin="5"/>
    </Grid>
</Window>
