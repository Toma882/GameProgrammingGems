<Window x:Class="GPGems.DemoApp.Graphics.CLODTerrainDemoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="🏔️ 连续LOD地形 - Game Programming Gems"
        Height="850" Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="#0f0f23">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="100"/>
        </Grid.RowDefinitions>

        <!-- 📖 顶部：算法说明区 -->
        <Border Grid.Row="0" Background="#1a1a2e" Padding="15">
            <StackPanel Orientation="Horizontal">
                <StackPanel>
                    <TextBlock Text="🏔️ 连续LOD地形 Continuous LOD" FontSize="18" Foreground="White" FontWeight="Bold"/>
                    <TextBlock Text="基于ROAM思想 - 二叉三角形剖分 + 逐帧自适应细化" FontSize="12" Foreground="#a0a0a0" Margin="0 3"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="50 0 0 0" VerticalAlignment="Center">
                    <Border Background="#16213e" Padding="10 5" CornerRadius="4" Margin="0 0 10 0">
                        <TextBlock x:Name="TriangleCountText" Text="三角面: 0" Foreground="#4ecca3" FontSize="12"/>
                    </Border>
                    <Border Background="#16213e" Padding="10 5" CornerRadius="4" Margin="0 0 10 0">
                        <TextBlock x:Name="DepthRangeText" Text="深度: 0-0" Foreground="#e94560" FontSize="12"/>
                    </Border>
                    <Border Background="#16213e" Padding="10 5" CornerRadius="4">
                        <TextBlock x:Name="ViewPosText" Text="观察点: (0,0)" Foreground="#f39c12" FontSize="12"/>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="250"/>
            </Grid.ColumnDefinitions>

            <!-- ⚙️ 左侧：参数调节区 -->
            <Border Grid.Column="0" Background="#1a1a2e" Margin="5" Padding="15" CornerRadius="8">
                <ScrollViewer>
                    <StackPanel>
                        <TextBlock Text="⚙️ 参数调节" FontSize="14" Foreground="White" FontWeight="Bold" Margin="0 0 0 15"/>

                        <!-- 地形大小 -->
                        <TextBlock Text="地形大小（2的幂+1）" Foreground="#a0a0a0" FontSize="11" Margin="0 10 0 3"/>
                        <Slider x:Name="TerrainSizeSlider" Minimum="17" Maximum="257" Value="65"
                                TickFrequency="32" IsSnapToTickEnabled="True"
                                Foreground="#4ecca3"/>
                        <TextBlock x:Name="TerrainSizeValue" Text="65" Foreground="White" FontSize="10" HorizontalAlignment="Right"/>

                        <!-- 最大剖分深度 -->
                        <TextBlock Text="最大剖分深度" Foreground="#a0a0a0" FontSize="11" Margin="0 10 0 3"/>
                        <Slider x:Name="MaxDepthSlider" Minimum="1" Maximum="10" Value="6"
                                TickFrequency="1" IsSnapToTickEnabled="True"
                                Foreground="#4ecca3"/>
                        <TextBlock x:Name="MaxDepthValue" Text="6" Foreground="White" FontSize="10" HorizontalAlignment="Right"/>

                        <!-- 误差阈值 -->
                        <TextBlock Text="剖分误差阈值" Foreground="#a0a0a0" FontSize="11" Margin="0 10 0 3"/>
                        <Slider x:Name="ErrorThresholdSlider" Minimum="0.1" Maximum="10" Value="1"
                                TickFrequency="0.5" IsSnapToTickEnabled="True"
                                Foreground="#4ecca3"/>
                        <TextBlock x:Name="ErrorThresholdValue" Text="1.0" Foreground="White" FontSize="10" HorizontalAlignment="Right"/>

                        <Button x:Name="RegenerateButton" Content="🔄 重新生成地形"
                                Background="#4ecca3" Foreground="White" FontWeight="Bold"
                                Padding="10" Margin="0 20 0 5" Click="RegenerateButton_Click"/>

                        <Button x:Name="AnimateViewButton" Content="▶ 自动漫游"
                                Background="#e94560" Foreground="White" FontWeight="Bold"
                                Padding="10" Margin="0 5" Click="AnimateViewButton_Click"/>

                        <CheckBox x:Name="ShowDepthColorsCheck" Content="按深度着色"
                                  IsChecked="True" Foreground="White" Margin="0 15 0 5"/>

                        <CheckBox x:Name="ShowEdgesCheck" Content="显示三角形边"
                                  IsChecked="True" Foreground="White" Margin="0 5"/>

                        <CheckBox x:Name="ShowSplitPointsCheck" Content="显示剖分点"
                                  IsChecked="False" Foreground="White" Margin="0 5"/>

                        <!-- 预设方案 -->
                        <TextBlock Text="📋 预设方案" Foreground="#a0a0a0" FontSize="11" Margin="0 20 0 10"/>

                        <Button Content="🏃 极速模式 (最小细节)" Background="#16213e" Foreground="White"
                                Padding="8" Margin="0 2" Click="PresetFast_Click"/>

                        <Button Content="⚖️ 标准模式" Background="#16213e" Foreground="White"
                                Padding="8" Margin="0 2" Click="PresetNormal_Click"/>

                        <Button Content="🎨 电影级 (最大细节)" Background="#16213e" Foreground="White"
                                Padding="8" Margin="0 2" Click="PresetBest_Click"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- 🖼️ 中央：主可视化区 -->
            <Border Grid.Column="1" Background="#0a0a1a" Margin="5 5 5 0" CornerRadius="8">
                <Grid>
                    <Canvas x:Name="DrawCanvas" Background="Transparent"
                            MouseMove="DrawCanvas_MouseMove"
                            MouseDown="DrawCanvas_MouseDown"
                            MouseWheel="DrawCanvas_MouseWheel"/>

                    <!-- 3D视角提示 -->
                    <Border Background="#16213eCC" Padding="8" CornerRadius="4"
                            HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="10">
                        <StackPanel>
                            <TextBlock Text="💡 鼠标移动 = 改变观察位置" Foreground="#a0a0a0" FontSize="10"/>
                            <TextBlock Text="滚轮 = 调整误差阈值" Foreground="#a0a0a0" FontSize="10"/>
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- 📊 右侧：性能监控区 -->
            <Border Grid.Column="2" Background="#1a1a2e" Margin="5" Padding="15" CornerRadius="8">
                <ScrollViewer>
                    <StackPanel>
                        <TextBlock Text="📊 性能监控" FontSize="14" Foreground="White" FontWeight="Bold" Margin="0 0 0 15"/>

                        <TextBlock Text="初始化时间" Foreground="#a0a0a0" FontSize="11" Margin="0 10 0 3"/>
                        <TextBlock x:Name="InitTimeText" Text="0 ms" Foreground="#e94560" FontSize="20" FontWeight="Bold"/>

                        <TextBlock Text="剖分更新时间" Foreground="#a0a0a0" FontSize="11" Margin="0 15 0 3"/>
                        <TextBlock x:Name="UpdateTimeText" Text="0 μs" Foreground="#4ecca3" FontSize="20" FontWeight="Bold"/>

                        <TextBlock Text="三角面数量" Foreground="#a0a0a0" FontSize="11" Margin="0 15 0 3"/>
                        <TextBlock x:Name="TriangleStatText" Text="0" Foreground="#f39c12" FontSize="20" FontWeight="Bold"/>

                        <Separator Background="#333" Margin="0 20"/>

                        <!-- 深度分布直方图 -->
                        <TextBlock Text="📊 剖分深度分布" FontSize="12" Foreground="White" FontWeight="Bold" Margin="0 0 0 10"/>
                        <ItemsControl x:Name="DepthDistributionList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Margin="0 2">
                                        <TextBlock Text="{Binding Label}" Width="30" Foreground="White" FontSize="10"/>
                                        <ProgressBar Value="{Binding Percent, Mode=OneWay}" Maximum="100" Height="12" Width="150"
                                                     Background="#16213e" Foreground="{Binding Color, Mode=OneWay}"/>
                                        <TextBlock Text="{Binding Count}" Width="40" Foreground="#a0a0a0" FontSize="10" Margin="5 0"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Separator Background="#333" Margin="0 20"/>

                        <TextBlock Text="💡 算法特点" FontSize="12" Foreground="#a0a0a0" Margin="0 0 0 10"/>
                        <TextBlock Text="二叉三角形剖分" Foreground="#4ecca3" FontSize="10" FontWeight="Bold" Margin="0 2"/>
                        <TextBlock Text="基于视点的细化" Foreground="#666" FontSize="10" Margin="0 2"/>
                        <TextBlock Text="几何误差 = 插值误差" Foreground="#666" FontSize="10" Margin="0 2"/>
                        <TextBlock Text="近处细、远处粗" Foreground="#666" FontSize="10" Margin="0 2"/>
                        <TextBlock Text="无裂缝 = 强制邻居同步" Foreground="#666" FontSize="10" Margin="0 2"/>

                        <Separator Background="#333" Margin="0 20"/>

                        <TextBlock Text="🎮 当前状态" FontSize="12" Foreground="White" FontWeight="Bold" Margin="0 0 0 10"/>
                        <TextBlock x:Name="AvgDepthText" Text="平均深度: 0" Foreground="#a0a0a0" FontSize="10" Margin="0 2"/>
                        <TextBlock x:Name="MaxReachedDepthText" Text="最大深度: 0" Foreground="#a0a0a0" FontSize="10" Margin="0 2"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- 📝 底部：日志输出区 -->
        <Border Grid.Row="2" Background="#0a0a1a" Margin="5 0 5 5" Padding="10" CornerRadius="8">
            <ScrollViewer>
                <TextBlock x:Name="LogText" Foreground="#4ecca3" FontFamily="Consolas" FontSize="11"/>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
