<Window x:Class="GPGems.DemoApp.Graphics.BSPTreeDemoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="🌳 BSP 树空间分割 - Game Programming Gems"
        Height="900" Width="1600"
        WindowStartupLocation="CenterScreen"
        Background="#0f0f23">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="80"/>
        </Grid.RowDefinitions>

        <!-- 📖 顶部：算法说明区 -->
        <Border Grid.Row="0" Background="#1a1a2e" Padding="15">
            <StackPanel Orientation="Horizontal">
                <StackPanel>
                    <TextBlock Text="🌳 BSP 二叉空间分割树" FontSize="18" Foreground="White" FontWeight="Bold"/>
                    <TextBlock Text="GPG 5 Chapter 1.05 | 多边形分割 · 画家算法 · 射线检测 · Portal可见性" FontSize="12" Foreground="#a0a0a0" Margin="0 3"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="50 0 0 0" VerticalAlignment="Center">
                    <Border Background="#16213e" Padding="10 5" CornerRadius="4" Margin="0 0 10 0">
                        <TextBlock x:Name="NodeCountText" Text="节点数: 0" Foreground="#e74c3c" FontSize="12"/>
                    </Border>
                    <Border Background="#16213e" Padding="10 5" CornerRadius="4" Margin="0 0 10 0">
                        <TextBlock x:Name="LeafCountText" Text="叶子数: 0" Foreground="#e74c3c" FontSize="12"/>
                    </Border>
                    <Border Background="#16213e" Padding="10 5" CornerRadius="4" Margin="0 0 10 0">
                        <TextBlock x:Name="PolygonCountText" Text="多边形数: 0" Foreground="#e74c3c" FontSize="12"/>
                    </Border>
                    <Border Background="#16213e" Padding="10 5" CornerRadius="4">
                        <TextBlock x:Name="DepthText" Text="最大深度: 0" Foreground="#e74c3c" FontSize="12"/>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="220"/>
            </Grid.ColumnDefinitions>

            <!-- ⚙️ 左侧：参数调节区 -->
            <Border Grid.Column="0" Background="#1a1a2e" Margin="5" Padding="12" CornerRadius="8">
                <ScrollViewer>
                    <StackPanel>
                        <TextBlock Text="⚙️ 参数调节" FontSize="14" Foreground="White" FontWeight="Bold" Margin="0 0 0 10"/>

                        <!-- 最大深度 -->
                        <TextBlock Text="最大深度" Foreground="#a0a0a0" FontSize="11" Margin="0 8 0 2"/>
                        <Slider x:Name="MaxDepthSlider" Minimum="2" Maximum="12" Value="6"
                                TickFrequency="1" IsSnapToTickEnabled="True"
                                Foreground="#e74c3c"/>
                        <TextBlock x:Name="MaxDepthValue" Text="6" Foreground="White" FontSize="10" HorizontalAlignment="Right"/>

                        <!-- 每叶子最大多边形数 -->
                        <TextBlock Text="每叶子最大多边形数" Foreground="#a0a0a0" FontSize="11" Margin="0 8 0 2"/>
                        <Slider x:Name="MaxPolygonsSlider" Minimum="1" Maximum="10" Value="4"
                                TickFrequency="1" IsSnapToTickEnabled="True"
                                Foreground="#e74c3c"/>
                        <TextBlock x:Name="MaxPolygonsValue" Text="4" Foreground="White" FontSize="10" HorizontalAlignment="Right"/>

                        <!-- 场景多边形数量 -->
                        <TextBlock Text="场景多边形数量" Foreground="#a0a0a0" FontSize="11" Margin="0 8 0 2"/>
                        <Slider x:Name="PolygonCountSlider" Minimum="10" Maximum="100" Value="40"
                                TickFrequency="5" IsSnapToTickEnabled="True"
                                Foreground="#e74c3c"/>
                        <TextBlock x:Name="PolygonCountValue" Text="40" Foreground="White" FontSize="10" HorizontalAlignment="Right"/>

                        <Button x:Name="RegenerateButton" Content="🔄 重新生成场景"
                                Background="#e74c3c" Foreground="White" FontWeight="Bold"
                                Padding="8" Margin="0 15 0 3" Click="RegenerateButton_Click"/>

                        <Separator Background="#333" Margin="0 15"/>

                        <!-- 显示选项 -->
                        <TextBlock Text="👁 显示选项" FontSize="12" Foreground="White" FontWeight="Bold" Margin="0 0 0 8"/>

                        <CheckBox x:Name="ShowSplitPlanesCheck" Content="显示分割平面"
                                  IsChecked="True" Foreground="White" Margin="0 3" Click="Redraw"/>

                        <CheckBox x:Name="ShowDepthColorsCheck" Content="按深度着色"
                                  IsChecked="True" Foreground="White" Margin="0 3" Click="Redraw"/>

                        <CheckBox x:Name="ShowNodeBoundsCheck" Content="显示节点边界"
                                  IsChecked="False" Foreground="White" Margin="0 3" Click="Redraw"/>

                        <CheckBox x:Name="ShowPolygonsCheck" Content="显示多边形"
                                  IsChecked="True" Foreground="White" Margin="0 3" Click="Redraw"/>

                        <Separator Background="#333" Margin="0 15"/>

                        <!-- 预设场景 -->
                        <TextBlock Text="📋 预设场景" Foreground="#a0a0a0" FontSize="11" Margin="0 0 0 8"/>

                        <Button Content="室内房间" Background="#16213e" Foreground="White"
                                Padding="6" Margin="0 2" Click="PresetRoom_Click" FontSize="11"/>

                        <Button Content="城市建筑" Background="#16213e" Foreground="White"
                                Padding="6" Margin="0 2" Click="PresetCity_Click" FontSize="11"/>

                        <Button Content="随机凸多边形" Background="#16213e" Foreground="White"
                                Padding="6" Margin="0 2" Click="PresetRandom_Click" FontSize="11"/>

                        <Separator Background="#333" Margin="0 15"/>

                        <!-- 操作按钮 -->
                        <TextBlock Text="🎮 操作" Foreground="#a0a0a0" FontSize="11" Margin="0 0 0 8"/>

                        <Button x:Name="RayCastButton" Content="🎯 射线检测模式"
                                Background="#3498db" Foreground="White" FontWeight="Bold"
                                Padding="6" Margin="0 2" Click="RayCastButton_Click" FontSize="11"/>

                        <Button x:Name="PainterSortButton" Content="🎨 画家算法排序"
                                Background="#2ecc71" Foreground="White" FontWeight="Bold"
                                Padding="6" Margin="0 2" Click="PainterSortButton_Click" FontSize="11"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- 🖼️ 中央：三视图可视化区 -->
            <Border Grid.Column="1" Background="#0a0a1a" Margin="5 5 5 0" CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左上：俯视图 + BSP 平面 -->
                    <Border Grid.Row="0" Grid.Column="0" Background="#0d0d20" Margin="3" BorderBrush="#333" BorderThickness="1">
                        <Grid>
                            <TextBlock Text="Top Down 俯视图 (BSP 分割平面)" Foreground="#888" FontSize="10" Margin="5" HorizontalAlignment="Left"/>
                            <Canvas x:Name="ViewTopDown" Background="Transparent"
                                    MouseMove="ViewTopDown_MouseMove"
                                    MouseLeftButtonDown="ViewTopDown_MouseLeftButtonDown"/>
                        </Grid>
                    </Border>

                    <!-- 右上：画家算法排序 -->
                    <Border Grid.Row="0" Grid.Column="1" Background="#0d0d20" Margin="3" BorderBrush="#333" BorderThickness="1">
                        <Grid>
                            <TextBlock Text="画家算法排序 (视点: 鼠标位置)" Foreground="#888" FontSize="10" Margin="5" HorizontalAlignment="Left"/>
                            <Canvas x:Name="ViewPainter" Background="Transparent"
                                    MouseMove="ViewPainter_MouseMove"/>
                        </Grid>
                    </Border>

                    <!-- 左下：射线检测 -->
                    <Border Grid.Row="1" Grid.Column="0" Background="#0d0d20" Margin="3" BorderBrush="#333" BorderThickness="1">
                        <Grid>
                            <TextBlock Text="射线检测 (点击设置起点, 移动设置方向)" Foreground="#888" FontSize="10" Margin="5" HorizontalAlignment="Left"/>
                            <Canvas x:Name="ViewRayCast" Background="Transparent"
                                    MouseMove="ViewRayCast_MouseMove"
                                    MouseLeftButtonDown="ViewRayCast_MouseLeftButtonDown"/>
                        </Grid>
                    </Border>

                    <!-- 右下：树结构可视化 -->
                    <Border Grid.Row="1" Grid.Column="1" Background="#0d0d20" Margin="3" BorderBrush="#333" BorderThickness="1">
                        <Grid>
                            <TextBlock Text="BSP 树结构" Foreground="#888" FontSize="10" Margin="5" HorizontalAlignment="Left"/>
                            <Canvas x:Name="ViewTreeStructure" Background="Transparent"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- 📊 右侧：性能监控 + 日志 -->
            <Border Grid.Column="2" Background="#1a1a2e" Margin="5" Padding="12" CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="📊 性能监控" FontSize="14" Foreground="White" FontWeight="Bold" Margin="0 0 0 12"/>

                    <TextBlock Text="BSP 构建耗时" Foreground="#a0a0a0" FontSize="11" Margin="0 8 0 2"/>
                    <TextBlock x:Name="BuildTimeText" Text="0 ms" Foreground="#e74c3c" FontSize="18" FontWeight="Bold"/>

                    <TextBlock Text="射线检测耗时" Foreground="#a0a0a0" FontSize="11" Margin="0 12 0 2"/>
                    <TextBlock x:Name="RayCastTimeText" Text="0 μs" Foreground="#3498db" FontSize="18" FontWeight="Bold"/>

                    <TextBlock Text="画家算法排序耗时" Foreground="#a0a0a0" FontSize="11" Margin="0 12 0 2"/>
                    <TextBlock x:Name="PainterTimeText" Text="0 μs" Foreground="#2ecc71" FontSize="18" FontWeight="Bold"/>

                    <TextBlock Text="射线命中数" Foreground="#a0a0a0" FontSize="11" Margin="0 12 0 2"/>
                    <TextBlock x:Name="RayHitCountText" Text="0" Foreground="#f39c12" FontSize="18" FontWeight="Bold"/>

                    <Separator Background="#333" Margin="0 15"/>

                    <TextBlock Text="💡 操作提示" FontSize="11" Foreground="#a0a0a0" Margin="0 0 0 8"/>
                    <TextBlock Text="鼠标移动: 更新视点位置" Foreground="#666" FontSize="10" Margin="0 2"/>
                    <TextBlock Text="点击: 设置射线起点" Foreground="#666" FontSize="10" Margin="0 2"/>
                    <TextBlock Text="右侧显示: 画家算法排序" Foreground="#666" FontSize="10" Margin="0 2"/>
                    <TextBlock Text="左下: 射线检测演示" Foreground="#666" FontSize="10" Margin="0 2"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- 📝 底部：日志输出区 -->
        <Border Grid.Row="2" Background="#0a0a1a" Margin="5 0 5 5" Padding="8" CornerRadius="8">
            <ScrollViewer>
                <TextBlock x:Name="LogText" Foreground="#e74c3c" FontFamily="Consolas" FontSize="10"/>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
