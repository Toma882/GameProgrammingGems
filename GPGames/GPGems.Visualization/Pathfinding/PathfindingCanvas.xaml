<UserControl x:Class="GPGems.Visualization.Pathfinding.PathfindingCanvas"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:GPGems.Visualization.Pathfinding"
             mc:Ignorable="d"
             d:DesignHeight="400" d:DesignWidth="400"
             Background="#0a192f">
    <Canvas x:Name="GridCanvas">
        <Canvas.RenderTransform>
            <ScaleTransform x:Name="GridScale" ScaleX="1" ScaleY="1"/>
        </Canvas.RenderTransform>
    </Canvas>
</UserControl>
