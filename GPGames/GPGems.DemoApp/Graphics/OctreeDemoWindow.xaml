<Window x:Class="GPGems.DemoApp.Graphics.OctreeDemoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="📦 八叉树 3D 空间分割 - Game Programming Gems"
        Height="900" Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="#0f0f23">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="80"/>
        </Grid.RowDefinitions>

        <!-- 📖 顶部：算法说明区 -->
        <Border Grid.Row="0" Background="#1a1a2e" Padding="15">
            <StackPanel Orientation="Horizontal">
                <StackPanel>
                    <TextBlock Text="📦 八叉树 3D 空间分割" FontSize="18" Foreground="White" FontWeight="Bold"/>
                    <TextBlock Text="GPG 1 - Polygonal 10 Ginsburg | 3D 八叉树 + 范围查询 + 射线查询" FontSize="12" Foreground="#a0a0a0" Margin="0 3"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="50 0 0 0" VerticalAlignment="Center">
                    <Border Background="#16213e" Padding="10 5" CornerRadius="4" Margin="0 0 10 0">
                        <TextBlock x:Name="NodeCountText" Text="节点数: 0" Foreground="#9b59b6" FontSize="12"/>
                    </Border>
                    <Border Background="#16213e" Padding="10 5" CornerRadius="4" Margin="0 0 10 0">
                        <TextBlock x:Name="PointCountText" Text="点数: 0" Foreground="#9b59b6" FontSize="12"/>
                    </Border>
                    <Border Background="#16213e" Padding="10 5" CornerRadius="4" Margin="0 0 10 0">
                        <TextBlock x:Name="LeafCountText" Text="叶子数: 0" Foreground="#9b59b6" FontSize="12"/>
                    </Border>
                    <Border Background="#16213e" Padding="10 5" CornerRadius="4">
                        <TextBlock x:Name="DepthText" Text="最大深度: 0" Foreground="#9b59b6" FontSize="12"/>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="220"/>
            </Grid.ColumnDefinitions>

            <!-- ⚙️ 左侧：参数调节区 -->
            <Border Grid.Column="0" Background="#1a1a2e" Margin="5" Padding="12" CornerRadius="8">
                <ScrollViewer>
                    <StackPanel>
                        <TextBlock Text="⚙️ 参数调节" FontSize="14" Foreground="White" FontWeight="Bold" Margin="0 0 0 10"/>

                        <!-- 最大深度 -->
                        <TextBlock Text="最大深度" Foreground="#a0a0a0" FontSize="11" Margin="0 8 0 2"/>
                        <Slider x:Name="MaxDepthSlider" Minimum="2" Maximum="8" Value="5"
                                TickFrequency="1" IsSnapToTickEnabled="True"
                                Foreground="#9b59b6"/>
                        <TextBlock x:Name="MaxDepthValue" Text="5" Foreground="White" FontSize="10" HorizontalAlignment="Right"/>

                        <!-- 每节点最大元素数 -->
                        <TextBlock Text="每节点最大元素数" Foreground="#a0a0a0" FontSize="11" Margin="0 8 0 2"/>
                        <Slider x:Name="MaxElementsSlider" Minimum="2" Maximum="16" Value="6"
                                TickFrequency="1" IsSnapToTickEnabled="True"
                                Foreground="#9b59b6"/>
                        <TextBlock x:Name="MaxElementsValue" Text="6" Foreground="White" FontSize="10" HorizontalAlignment="Right"/>

                        <!-- 点数量 -->
                        <TextBlock Text="随机点数量" Foreground="#a0a0a0" FontSize="11" Margin="0 8 0 2"/>
                        <Slider x:Name="PointCountSlider" Minimum="200" Maximum="3000" Value="800"
                                TickFrequency="100" IsSnapToTickEnabled="True"
                                Foreground="#9b59b6"/>
                        <TextBlock x:Name="PointCountValue" Text="800" Foreground="White" FontSize="10" HorizontalAlignment="Right"/>

                        <Button x:Name="RegenerateButton" Content="🔄 重新生成点云"
                                Background="#9b59b6" Foreground="White" FontWeight="Bold"
                                Padding="8" Margin="0 15 0 3" Click="RegenerateButton_Click"/>

                        <Separator Background="#333" Margin="0 15"/>

                        <!-- 显示选项 -->
                        <TextBlock Text="👁 显示选项" FontSize="12" Foreground="White" FontWeight="Bold" Margin="0 0 0 8"/>

                        <CheckBox x:Name="ShowBoundsCheck" Content="显示节点边界"
                                  IsChecked="True" Foreground="White" Margin="0 3" Click="Redraw"/>

                        <CheckBox x:Name="ShowPointsCheck" Content="显示点云"
                                  IsChecked="True" Foreground="White" Margin="0 3" Click="Redraw"/>

                        <CheckBox x:Name="ShowDepthColorsCheck" Content="按深度着色"
                                  IsChecked="True" Foreground="White" Margin="0 3" Click="Redraw"/>

                        <Separator Background="#333" Margin="0 15"/>

                        <!-- 预设方案 -->
                        <TextBlock Text="📋 预设方案" Foreground="#a0a0a0" FontSize="11" Margin="0 0 0 8"/>

                        <Button Content="均衡模式" Background="#16213e" Foreground="White"
                                Padding="6" Margin="0 2" Click="PresetBalanced_Click" FontSize="11"/>

                        <Button Content="高性能（少节点）" Background="#16213e" Foreground="White"
                                Padding="6" Margin="0 2" Click="PresetHighPerformance_Click" FontSize="11"/>

                        <Button Content="高质量（细分割）" Background="#16213e" Foreground="White"
                                Padding="6" Margin="0 2" Click="PresetHighQuality_Click" FontSize="11"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- 🖼️ 中央：四视图 3D 可视化区 -->
            <Border Grid.Column="1" Background="#0a0a1a" Margin="5 5 5 0" CornerRadius="8">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左上：XY 平面俯视图 -->
                    <Border Grid.Row="0" Grid.Column="0" Background="#0d0d20" Margin="3" BorderBrush="#333" BorderThickness="1">
                        <Grid>
                            <TextBlock Text="XY 俯视图" Foreground="#888" FontSize="10" Margin="5" HorizontalAlignment="Left"/>
                            <Canvas x:Name="ViewXY" Background="Transparent"
                                    MouseMove="ViewXY_MouseMove" Tag="XY"/>
                        </Grid>
                    </Border>

                    <!-- 右上：XZ 平面前视图 -->
                    <Border Grid.Row="0" Grid.Column="1" Background="#0d0d20" Margin="3" BorderBrush="#333" BorderThickness="1">
                        <Grid>
                            <TextBlock Text="XZ 前视图" Foreground="#888" FontSize="10" Margin="5" HorizontalAlignment="Left"/>
                            <Canvas x:Name="ViewXZ" Background="Transparent"
                                    MouseMove="ViewXZ_MouseMove" Tag="XZ"/>
                        </Grid>
                    </Border>

                    <!-- 左下：YZ 平面侧视图 -->
                    <Border Grid.Row="1" Grid.Column="0" Background="#0d0d20" Margin="3" BorderBrush="#333" BorderThickness="1">
                        <Grid>
                            <TextBlock Text="YZ 侧视图" Foreground="#888" FontSize="10" Margin="5" HorizontalAlignment="Left"/>
                            <Canvas x:Name="ViewYZ" Background="Transparent"
                                    MouseMove="ViewYZ_MouseMove" Tag="YZ"/>
                        </Grid>
                    </Border>

                    <!-- 右下：3D 斜投影视图 -->
                    <Border Grid.Row="1" Grid.Column="1" Background="#0d0d20" Margin="3" BorderBrush="#333" BorderThickness="1">
                        <Grid>
                            <TextBlock Text="3D 斜投影" Foreground="#888" FontSize="10" Margin="5" HorizontalAlignment="Left"/>
                            <Canvas x:Name="View3D" Background="Transparent"
                                    MouseMove="View3D_MouseMove" Tag="3D"/>
                        </Grid>
                    </Border>
                </Grid>
            </Border>

            <!-- 📊 右侧：性能监控 + 日志 -->
            <Border Grid.Column="2" Background="#1a1a2e" Margin="5" Padding="12" CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="📊 性能监控" FontSize="14" Foreground="White" FontWeight="Bold" Margin="0 0 0 12"/>

                    <TextBlock Text="构建耗时" Foreground="#a0a0a0" FontSize="11" Margin="0 8 0 2"/>
                    <TextBlock x:Name="BuildTimeText" Text="0 ms" Foreground="#9b59b6" FontSize="18" FontWeight="Bold"/>

                    <TextBlock Text="范围查询耗时" Foreground="#a0a0a0" FontSize="11" Margin="0 12 0 2"/>
                    <TextBlock x:Name="QueryTimeText" Text="0 μs" Foreground="#4ecca3" FontSize="18" FontWeight="Bold"/>

                    <TextBlock Text="查询结果数" Foreground="#a0a0a0" FontSize="11" Margin="0 12 0 2"/>
                    <TextBlock x:Name="QueryResultText" Text="0" Foreground="#f39c12" FontSize="18" FontWeight="Bold"/>

                    <TextBlock Text="射线查询耗时" Foreground="#a0a0a0" FontSize="11" Margin="0 12 0 2"/>
                    <TextBlock x:Name="RayQueryTimeText" Text="0 μs" Foreground="#e74c3c" FontSize="18" FontWeight="Bold"/>

                    <Separator Background="#333" Margin="0 15"/>

                    <TextBlock Text="💡 操作提示" FontSize="11" Foreground="#a0a0a0" Margin="0 0 0 8"/>
                    <TextBlock Text="鼠标移动: 范围查询" Foreground="#666" FontSize="10" Margin="0 2"/>
                    <TextBlock Text="各视图独立查询" Foreground="#666" FontSize="10" Margin="0 2"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- 📝 底部：日志输出区 -->
        <Border Grid.Row="2" Background="#0a0a1a" Margin="5 0 5 5" Padding="8" CornerRadius="8">
            <ScrollViewer>
                <TextBlock x:Name="LogText" Foreground="#9b59b6" FontFamily="Consolas" FontSize="10"/>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
