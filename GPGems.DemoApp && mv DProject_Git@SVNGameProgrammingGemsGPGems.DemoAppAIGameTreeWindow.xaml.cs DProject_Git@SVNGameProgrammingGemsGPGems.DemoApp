<Window x:Class="GPGems.DemoApp.AI.GameTreeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GPGems.DemoApp"
        xmlns:tt="clr-namespace:GPGems.Visualization.TicTacToe;assembly=GPGems.Visualization"
        xmlns:ScottPlot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
        mc:Ignorable="d"
        Title="博弈树 AI 演示 - Alpha-Beta 剪枝" Height="800" Width="1200"
        WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="350"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧：游戏面板 -->
        <Border Grid.Column="0" Padding="20" Background="#f5f5f5">
            <StackPanel>
                <TextBlock Text="井字棋 - 博弈树 AI" FontSize="20" FontWeight="Bold" Margin="0 0 0 20"/>

                <!-- 游戏设置 -->
                <GroupBox Header="设置" Margin="0 0 0 10">
                    <StackPanel Margin="5">
                        <TextBlock Text="搜索深度:"/>
                        <Slider x:Name="DepthSlider" Minimum="1" Maximum="8" Value="4"
                                TickFrequency="1" IsSnapToTickEnabled="True"
                                ValueChanged="DepthSlider_ValueChanged"/>
                        <TextBlock Text="{Binding ElementName=DepthSlider, Path=Value, StringFormat=当前深度: {0}}"
                                   Margin="0 5 0 0"/>

                        <CheckBox x:Name="AiStartsCheckBox" Content="AI 先手" Margin="0 10 0 0"
                                  IsChecked="True"/>
                    </StackPanel>
                </GroupBox>

                <!-- 游戏状态 -->
                <GroupBox Header="游戏状态" Margin="0 0 0 10">
                    <StackPanel Margin="5">
                        <TextBlock x:Name="StatusText" Text="点击棋盘开始游戏" FontSize="14" Margin="0 5"/>
                        <TextBlock x:Name="CurrentPlayerText" Text="当前玩家: X" FontSize="14" FontWeight="Bold" Margin="0 5"/>
                    </StackPanel>
                </GroupBox>

                <!-- 统计信息 -->
                <GroupBox Header="搜索统计" Margin="0 0 0 10">
                    <StackPanel Margin="5">
                        <TextBlock x:Name="TotalNodesText" Text="总节点数: 0"/>
                        <TextBlock x:Name="PrunedNodesText" Text="剪枝节点数: 0"/>
                        <TextBlock x:Name="PruneRateText" Text="剪枝率: 0%"/>
                    </StackPanel>
                </GroupBox>

                <!-- 操作按钮 -->
                <StackPanel Orientation="Horizontal" Margin="0 10">
                    <Button x:Name="NewGameBtn" Content="新游戏" Click="NewGameBtn_Click"
                            Padding="10 5" Margin="0 0 5 0" Background="#4CAF50" Foreground="White" BorderThickness="0"/>
                    <Button x:Name="UndoBtn" Content="悔棋" Click="UndoBtn_Click"
                            Padding="10 5" Background="#2196F3" Foreground="White" BorderThickness="0"/>
                </StackPanel>

                <!-- 棋盘 -->
                <Border BorderBrush="Gray" BorderThickness="1" Margin="0 20"
                        HorizontalAlignment="Center">
                    <tt:TicTacToeBoard x:Name="GameBoard" Width="300" Height="300"
                                        CellClicked="GameBoard_CellClicked"/>
                </Border>
            </StackPanel>
        </Border>

        <!-- 右侧：搜索树可视化 -->
        <Border Grid.Column="1" Padding="10">
            <StackPanel>
                <TextBlock Text="Alpha-Beta 搜索树" FontSize="16" FontWeight="Bold" Margin="0 0 0 10"/>

                <!-- 图例 -->
                <StackPanel Orientation="Horizontal" Margin="0 0 0 10">
                    <Rectangle Width="15" Height="15" Fill="#ccffcc" Stroke="Green" StrokeThickness="2" Margin="0 0 3 0"/>
                    <TextBlock Text="最佳路径" Margin="0 0 10 0"/>
                    <Rectangle Width="15" Height="15" Fill="#ffcccc" Stroke="Red" Margin="0 0 3 0"/>
                    <TextBlock Text="被剪枝" Margin="0 0 10 0"/>
                    <Rectangle Width="15" Height="15" Fill="#e8e8e8" Stroke="Gray" Margin="0 0 3 0"/>
                    <TextBlock Text="普通节点"/>
                </StackPanel>

                <!-- ScottPlot 图表控件 -->
                <Border BorderBrush="Gray" BorderThickness="1" CornerRadius="3"
                        Height="550" Background="White">
                    <ScottPlot:WpfPlot x:Name="SearchTreePlot"/>
                </Border>
            </StackPanel>
        </Border>
    </Grid>
</Window>
