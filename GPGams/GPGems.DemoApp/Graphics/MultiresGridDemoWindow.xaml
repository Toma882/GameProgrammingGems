<Window x:Class="GPGems.DemoApp.Graphics.MultiresGridDemoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="📊 多分辨率栅格 Chunked LOD - Game Programming Gems"
        Height="850" Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="#0f0f23">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="100"/>
        </Grid.RowDefinitions>

        <!-- 📖 顶部：算法说明区 -->
        <Border Grid.Row="0" Background="#1a1a2e" Padding="15">
            <StackPanel Orientation="Horizontal">
                <StackPanel>
                    <TextBlock Text="📊 多分辨率栅格 Chunked LOD" FontSize="18" Foreground="White" FontWeight="Bold"/>
                    <TextBlock Text="GPG 1 - Polygonal Chapter | 四叉树驱动的地形分块LOD系统" FontSize="12" Foreground="#a0a0a0" Margin="0 3"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="50 0 0 0" VerticalAlignment="Center">
                    <Border Background="#16213e" Padding="10 5" CornerRadius="4" Margin="0 0 10 0">
                        <TextBlock x:Name="ChunkCountText" Text="块数: 0" Foreground="#4ecca3" FontSize="12"/>
                    </Border>
                    <Border Background="#16213e" Padding="10 5" CornerRadius="4" Margin="0 0 10 0">
                        <TextBlock x:Name="TriangleCountText" Text="三角面: 0" Foreground="#4ecca3" FontSize="12"/>
                    </Border>
                    <Border Background="#16213e" Padding="10 5" CornerRadius="4" Margin="0 0 10 0">
                        <TextBlock x:Name="LODRangeText" Text="LOD层级: 0-0" Foreground="#e94560" FontSize="12"/>
                    </Border>
                    <Border Background="#16213e" Padding="10 5" CornerRadius="4">
                        <TextBlock x:Name="ViewPosText" Text="观察点: (0,0)" Foreground="#f39c12" FontSize="12"/>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="250"/>
            </Grid.ColumnDefinitions>

            <!-- ⚙️ 左侧：参数调节区 -->
            <Border Grid.Column="0" Background="#1a1a2e" Margin="5" Padding="15" CornerRadius="8">
                <ScrollViewer>
                    <StackPanel>
                        <TextBlock Text="⚙️ 参数调节" FontSize="14" Foreground="White" FontWeight="Bold" Margin="0 0 0 15"/>

                        <!-- 地形大小 -->
                        <TextBlock Text="地形网格大小" Foreground="#a0a0a0" FontSize="11" Margin="0 10 0 3"/>
                        <Slider x:Name="TerrainSizeSlider" Minimum="33" Maximum="257" Value="129"
                                TickFrequency="32" IsSnapToTickEnabled="True"
                                Foreground="#4ecca3"/>
                        <TextBlock x:Name="TerrainSizeValue" Text="129" Foreground="White" FontSize="10" HorizontalAlignment="Right"/>

                        <!-- 块大小 -->
                        <TextBlock Text="分块大小" Foreground="#a0a0a0" FontSize="11" Margin="0 10 0 3"/>
                        <Slider x:Name="ChunkSizeSlider" Minimum="8" Maximum="64" Value="16"
                                TickFrequency="8" IsSnapToTickEnabled="True"
                                Foreground="#4ecca3"/>
                        <TextBlock x:Name="ChunkSizeValue" Text="16" Foreground="White" FontSize="10" HorizontalAlignment="Right"/>

                        <!-- 最大LOD层级 -->
                        <TextBlock Text="最大LOD层级" Foreground="#a0a0a0" FontSize="11" Margin="0 10 0 3"/>
                        <Slider x:Name="MaxLODSlider" Minimum="1" Maximum="8" Value="5"
                                TickFrequency="1" IsSnapToTickEnabled="True"
                                Foreground="#4ecca3"/>
                        <TextBlock x:Name="MaxLODValue" Text="5" Foreground="White" FontSize="10" HorizontalAlignment="Right"/>

                        <!-- LOD距离因子 -->
                        <TextBlock Text="LOD切换距离" Foreground="#a0a0a0" FontSize="11" Margin="0 10 0 3"/>
                        <Slider x:Name="LODDistanceSlider" Minimum="50" Maximum="500" Value="200"
                                TickFrequency="50" IsSnapToTickEnabled="True"
                                Foreground="#4ecca3"/>
                        <TextBlock x:Name="LODDistanceValue" Text="200" Foreground="White" FontSize="10" HorizontalAlignment="Right"/>

                        <Button x:Name="RegenerateButton" Content="🔄 重新生成地形"
                                Background="#4ecca3" Foreground="White" FontWeight="Bold"
                                Padding="10" Margin="0 20 0 5" Click="RegenerateButton_Click"/>

                        <Button x:Name="AnimateViewButton" Content="▶ 自动漫游"
                                Background="#e94560" Foreground="White" FontWeight="Bold"
                                Padding="10" Margin="0 5" Click="AnimateViewButton_Click"/>

                        <CheckBox x:Name="ShowLODColorsCheck" Content="按LOD着色"
                                  IsChecked="True" Foreground="White" Margin="0 15 0 5"/>

                        <CheckBox x:Name="ShowChunkBoundsCheck" Content="显示块边界"
                                  IsChecked="True" Foreground="White" Margin="0 5"/>

                        <CheckBox x:Name="ShowWireframeCheck" Content="线框模式"
                                  IsChecked="False" Foreground="White" Margin="0 5"/>

                        <!-- 预设方案 -->
                        <TextBlock Text="📋 预设方案" Foreground="#a0a0a0" FontSize="11" Margin="0 20 0 10"/>

                        <Button Content="🏃 高性能模式" Background="#16213e" Foreground="White"
                                Padding="8" Margin="0 2" Click="PresetPerformance_Click"/>

                        <Button Content="⚖️ 均衡模式" Background="#16213e" Foreground="White"
                                Padding="8" Margin="0 2" Click="PresetBalanced_Click"/>

                        <Button Content="🎨 高质量模式" Background="#16213e" Foreground="White"
                                Padding="8" Margin="0 2" Click="PresetQuality_Click"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- 🖼️ 中央：主可视化区 -->
            <Border Grid.Column="1" Background="#0a0a1a" Margin="5 5 5 0" CornerRadius="8">
                <Grid>
                    <Canvas x:Name="DrawCanvas" Background="Transparent"
                            MouseMove="DrawCanvas_MouseMove"
                            MouseDown="DrawCanvas_MouseDown"/>

                    <!-- 3D视角提示 -->
                    <Border Background="#16213eCC" Padding="8" CornerRadius="4"
                            HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="10">
                        <TextBlock Text="💡 鼠标移动 = 改变观察位置" Foreground="#a0a0a0" FontSize="10"/>
                    </Border>
                </Grid>
            </Border>

            <!-- 📊 右侧：性能监控区 -->
            <Border Grid.Column="2" Background="#1a1a2e" Margin="5" Padding="15" CornerRadius="8">
                <ScrollViewer>
                    <StackPanel>
                        <TextBlock Text="📊 性能监控" FontSize="14" Foreground="White" FontWeight="Bold" Margin="0 0 0 15"/>

                        <TextBlock Text="地形生成时间" Foreground="#a0a0a0" FontSize="11" Margin="0 10 0 3"/>
                        <TextBlock x:Name="GenTimeText" Text="0 ms" Foreground="#e94560" FontSize="20" FontWeight="Bold"/>

                        <TextBlock Text="LOD更新时间" Foreground="#a0a0a0" FontSize="11" Margin="0 15 0 3"/>
                        <TextBlock x:Name="LODUpdateTimeText" Text="0 ms" Foreground="#4ecca3" FontSize="20" FontWeight="Bold"/>

                        <TextBlock Text="三角面缩减率" Foreground="#a0a0a0" FontSize="11" Margin="0 15 0 3"/>
                        <TextBlock x:Name="ReductionText" Text="0%" Foreground="#f39c12" FontSize="20" FontWeight="Bold"/>

                        <Separator Background="#333" Margin="0 20"/>

                        <!-- LOD层级分布 -->
                        <TextBlock Text="LOD层级分布" FontSize="12" Foreground="White" FontWeight="Bold" Margin="0 0 0 10"/>
                        <ItemsControl x:Name="LODDistributionList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <ProgressBar Value="{Binding Percent, Mode=OneWay}" Maximum="100" Height="12" Margin="0 2"
                                                 Background="#16213e" Foreground="{Binding Color, Mode=OneWay}"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Separator Background="#333" Margin="0 20"/>

                        <TextBlock Text="💡 LOD层级说明" FontSize="12" Foreground="#a0a0a0" Margin="0 0 0 10"/>
                        <TextBlock Text="🟢 LOD 0: 最高细节 (近处)" Foreground="#00ff88" FontSize="10" Margin="0 2"/>
                        <TextBlock Text="🟡 LOD 1-2: 中等细节" Foreground="#ffdd00" FontSize="10" Margin="0 2"/>
                        <TextBlock Text="🟠 LOD 3-4: 较低细节" Foreground="#ff8800" FontSize="10" Margin="0 2"/>
                        <TextBlock Text="🔴 LOD 5+: 最低细节 (远处)" Foreground="#ff4444" FontSize="10" Margin="0 2"/>

                        <Separator Background="#333" Margin="0 20"/>

                        <TextBlock Text="📈 统计信息" FontSize="12" Foreground="White" FontWeight="Bold" Margin="0 0 0 10"/>
                        <TextBlock x:Name="StatMaxLODText" Text="最高LOD: 0" Foreground="#a0a0a0" FontSize="10" Margin="0 2"/>
                        <TextBlock x:Name="StatMinLODText" Text="最低LOD: 0" Foreground="#a0a0a0" FontSize="10" Margin="0 2"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- 📝 底部：日志输出区 -->
        <Border Grid.Row="2" Background="#0a0a1a" Margin="5 0 5 5" Padding="10" CornerRadius="8">
            <ScrollViewer>
                <TextBlock x:Name="LogText" Foreground="#4ecca3" FontFamily="Consolas" FontSize="11"/>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
