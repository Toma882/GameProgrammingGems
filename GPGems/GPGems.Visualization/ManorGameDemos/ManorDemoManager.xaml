<UserControl x:Class="GPGems.Visualization.ManorGameDemos.ManorDemoManager"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="600" d:DesignWidth="900">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- 左侧控制面板 -->
        <Border Grid.Column="0" Background="#F0F0F0" Padding="0">
            <ScrollViewer Padding="10" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                <TextBlock Text="🏰 经营游戏算法演示" FontSize="14" FontWeight="Bold" Margin="0 0 0 15"/>

                <!-- 庄园模拟控制面板 -->
                <TextBlock Text="🏰 庄园整合模拟" FontSize="12" FontWeight="Bold" Margin="0 0 0 10"/>

                <!-- 控制按钮 -->
                <StackPanel Orientation="Horizontal" Margin="0 0 0 15">
                    <Button x:Name="BtnPlayPause" Content="▶ 播放" Click="BtnPlayPause_Click" Width="80" Margin="0 0 5 0"/>
                    <Button x:Name="BtnReset" Content="🔄 重置" Click="BtnReset_Click" Width="80"/>
                </StackPanel>

                <Separator Margin="0 0 0 10"/>

                <!-- 参数调优区 -->
                <TextBlock Text="⚙️ 参数调整" FontWeight="Bold" Margin="0 0 0 10"/>

                <!-- 人数滑块 -->
                <StackPanel Margin="0 0 0 10">
                    <TextBlock Text="人数/动物数:" FontSize="11"/>
                    <Slider x:Name="SliderCount" Minimum="10" Maximum="500" Value="100"
                            IsSnapToTickEnabled="True" TickFrequency="10"/>
                    <TextBlock Text="{Binding Value, ElementName=SliderCount, StringFormat={}当前: {0}}" FontSize="10"/>
                </StackPanel>

                <!-- 速度滑块 -->
                <StackPanel Margin="0 0 0 10">
                    <TextBlock Text="移动速度:" FontSize="11"/>
                    <Slider x:Name="SliderSpeed" Minimum="0.1" Maximum="3" Value="1"
                            IsSnapToTickEnabled="True" TickFrequency="0.1"/>
                    <TextBlock Text="{Binding Value, ElementName=SliderSpeed, StringFormat={}倍率: {0:F1}x}" FontSize="10"/>
                </StackPanel>

                <Separator Margin="0 10 0 10"/>

                <!-- 实时统计 -->
                <TextBlock Text="📊 实时统计" FontWeight="Bold" Margin="0 0 0 10"/>
                <TextBlock x:Name="StatsFPS" Text="FPS: --" FontSize="11"/>
                <TextBlock x:Name="StatsFrame" Text="帧数: 0" FontSize="11"/>
                <TextBlock x:Name="StatsTime" Text="模拟时间: 0.0s" FontSize="11"/>
                <TextBlock x:Name="StatsCollisions" Text="每帧碰撞: 0" FontSize="11" Margin="0 5 0 0"/>
                <TextBlock x:Name="StatsThroughput" Text="吞吐量: 0/秒" FontSize="11"/>

                <Separator Margin="0 10 0 10"/>

                <!-- 场景说明 -->
                <TextBlock x:Name="SceneDescription" TextWrapping="Wrap" FontSize="10" Foreground="#555">
                    整合多种算法的庄园经营模拟：流场寻路 + ORCA避障 + Boids群体 + 任务调度 + 社会力疏散
                </TextBlock>

                <!-- 整合庄园场景面板 -->
                <StackPanel x:Name="IntegratedPanel" Margin="0 10 0 0">
                    <Separator Margin="0 0 0 10"/>
                    <TextBlock Text="🏰 整合庄园模拟" FontWeight="Bold" Margin="0 0 0 10"/>

                    <!-- 楼层选择 -->
                    <TextBlock Text="当前楼层:" FontSize="11" Margin="0 0 0 5"/>
                    <StackPanel Orientation="Horizontal" Margin="0 0 0 10">
                        <RadioButton x:Name="IntFloor0" Content="一楼" IsChecked="True" GroupName="IntFloorGroup" Checked="IntFloor_Checked"/>
                        <RadioButton x:Name="IntFloor1" Content="二楼" Margin="10 0 0 0" GroupName="IntFloorGroup" Checked="IntFloor_Checked"/>
                        <RadioButton x:Name="IntFloor2" Content="三楼" Margin="10 0 0 0" GroupName="IntFloorGroup" Checked="IntFloor_Checked"/>
                    </StackPanel>

                    <!-- 建筑物选择 -->
                    <TextBlock Text="选择建筑物:" FontSize="11" Margin="0 0 0 5"/>
                    <ComboBox x:Name="IntegratedBuildingSelector" SelectionChanged="IntegratedBuildingSelector_SelectionChanged" Margin="0 0 0 10">
                        <ComboBoxItem Content="入口 (3×2)" Tag="0"/>
                        <ComboBoxItem Content="出口 (3×2)" Tag="1"/>
                        <ComboBoxItem Content="景点 (4×4)" Tag="2"/>
                        <ComboBoxItem Content="商店 (2×2)" Tag="3"/>
                        <ComboBoxItem Content="餐厅 (4×3)" Tag="4"/>
                        <ComboBoxItem Content="楼梯 (2×1)" Tag="5"/>
                        <ComboBoxItem Content="员工宿舍 (4×4)" Tag="6"/>
                        <ComboBoxItem Content="收获点 (2×2)" Tag="7"/>
                        <ComboBoxItem Content="喂养点 (2×2)" Tag="8"/>
                        <ComboBoxItem Content="服务点 (2×2)" Tag="9"/>
                    </ComboBox>
                    <Button x:Name="BtnIntPlace" Content="📍 放置建筑" Click="BtnIntPlace_Click" Margin="0 0 0 5"/>
                    <Button x:Name="BtnIntClear" Content="🗑️ 清空" Click="BtnIntClear_Click" Margin="0 0 0 5"/>

                    <Separator Margin="0 5 0 5"/>

                    <!-- 模拟系统开关 -->
                    <TextBlock Text="🔧 模拟系统开关" FontWeight="Bold" Margin="0 0 0 5"/>

                    <CheckBox x:Name="ChkVisitorFlow" Content="🚶 游客人流 (流场+ORCA)" IsChecked="True" Margin="0 2 0 2"/>
                    <CheckBox x:Name="ChkAnimalGroup" Content="🐟 动物群体 (Boids)" IsChecked="False" Margin="0 2 0 2"/>
                    <CheckBox x:Name="ChkEmployeeTask" Content="👷 员工任务 (A*+FSM)" IsChecked="False" Margin="0 2 0 2"/>
                    <CheckBox x:Name="ChkEvacuation" Content="🚨 紧急疏散 (社会力)" IsChecked="False" Margin="0 2 0 2"/>

                    <Separator Margin="0 5 0 5"/>

                    <!-- 游客参数 -->
                    <StackPanel x:Name="VisitorParamsPanel" Margin="0 0 0 5">
                        <TextBlock Text="🚶 游客参数:" FontSize="11" FontWeight="Bold"/>
                        <TextBlock Text="游客数量:" FontSize="10"/>
                        <Slider x:Name="SliderVisitorCount" Minimum="10" Maximum="500" Value="100" IsSnapToTickEnabled="True" TickFrequency="10"/>
                        <TextBlock Text="游客速度:" FontSize="10"/>
                        <Slider x:Name="SliderVisitorSpeed" Minimum="0.1" Maximum="3" Value="1" TickFrequency="0.1"/>
                        <CheckBox x:Name="ChkORCA" Content="启用 ORCA 避障" IsChecked="True" Margin="0 2 0 2"/>
                    </StackPanel>

                    <!-- 动物参数 -->
                    <StackPanel x:Name="AnimalParamsPanel" Margin="0 0 0 5">
                        <TextBlock Text="🐟 动物参数:" FontSize="11" FontWeight="Bold"/>
                        <TextBlock Text="动物数量:" FontSize="10"/>
                        <Slider x:Name="SliderAnimalCount" Minimum="10" Maximum="200" Value="50" IsSnapToTickEnabled="True" TickFrequency="10"/>
                        <TextBlock Text="凝聚系数:" FontSize="10"/>
                        <Slider x:Name="SliderCohesion" Minimum="0" Maximum="2" Value="1" TickFrequency="0.1"/>
                        <TextBlock Text="同步系数:" FontSize="10"/>
                        <Slider x:Name="SliderAlignment" Minimum="0" Maximum="2" Value="1" TickFrequency="0.1"/>
                        <TextBlock Text="分离系数:" FontSize="10"/>
                        <Slider x:Name="SliderSeparation" Minimum="0" Maximum="3" Value="1.5" TickFrequency="0.1"/>
                    </StackPanel>

                    <!-- 员工参数 -->
                    <StackPanel x:Name="EmployeeParamsPanel" Margin="0 0 0 5">
                        <TextBlock Text="👷 员工参数:" FontSize="11" FontWeight="Bold"/>
                        <TextBlock Text="员工数量:" FontSize="10"/>
                        <Slider x:Name="SliderEmployeeCount" Minimum="1" Maximum="20" Value="5" IsSnapToTickEnabled="True" TickFrequency="1"/>
                        <TextBlock Text="任务数量:" FontSize="10"/>
                        <Slider x:Name="SliderTaskCount" Minimum="1" Maximum="50" Value="10" IsSnapToTickEnabled="True" TickFrequency="1"/>
                    </StackPanel>

                    <!-- 疏散参数 -->
                    <StackPanel x:Name="EvacuationParamsPanel" Margin="0 0 0 5">
                        <TextBlock Text="🚨 疏散参数:" FontSize="11" FontWeight="Bold"/>
                        <TextBlock Text="疏散人数:" FontSize="10"/>
                        <Slider x:Name="SliderEvacCount" Minimum="50" Maximum="1000" Value="300" IsSnapToTickEnabled="True" TickFrequency="50"/>
                    </StackPanel>

                    <TextBlock Text="💡 先放置入口/出口/景点，再点击顶部播放按钮" FontSize="10" Foreground="#888" Margin="0 5 0 0"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Border>

        <!-- 右侧渲染画布 -->
        <Border Grid.Column="1" Background="White">
            <Grid>
                <Canvas x:Name="RenderCanvas" Background="#1A1A2E"/>
                <!-- 小地图覆盖层 -->
                <Border x:Name="MiniMapBorder" HorizontalAlignment="Right" VerticalAlignment="Top"
                        Margin="10" Background="#AA000000" Width="150" Height="150" Visibility="Collapsed">
                    <Canvas x:Name="MiniMapCanvas"/>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
