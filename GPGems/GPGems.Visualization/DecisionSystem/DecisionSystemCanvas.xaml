<UserControl x:Class="GPGems.Visualization.DecisionSystem.DecisionSystemCanvas"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:ScottPlot="clr-namespace:ScottPlot.WPF;assembly=ScottPlot.WPF"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="1200"
             Background="#0f0f23">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
            <TextBlock Text="🎯 融合决策系统可视化演示" FontSize="18" FontWeight="Bold"
                       Foreground="White" VerticalAlignment="Center"/>
            <Button x:Name="BtnStart" Content="▶ 开始模拟" Margin="20,0,10,0"
                    Padding="15,5" Background="#2196F3" Foreground="White" BorderThickness="0"
                    Click="BtnStart_Click"/>
            <Button x:Name="BtnPause" Content="⏸ 暂停" Margin="0,0,10,0"
                    Padding="15,5" Background="#FF9800" Foreground="White" BorderThickness="0"
                    Click="BtnPause_Click"/>
            <Button x:Name="BtnReset" Content="↻ 重置" Margin="0,0,10,0"
                    Padding="15,5" Background="#4CAF50" Foreground="White" BorderThickness="0"
                    Click="BtnReset_Click"/>
            <Button x:Name="BtnStep" Content="⏭ 单步" Margin="0,0,10,0"
                    Padding="15,5" Background="#9C27B0" Foreground="White" BorderThickness="0"
                    Click="BtnStep_Click"/>
            <TextBlock x:Name="FrameText" Text="Frame: 0" Foreground="White"
                       VerticalAlignment="Center" Margin="20,0,0,0"/>
        </StackPanel>

        <!-- 主内容区 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="300"/>
            </Grid.ColumnDefinitions>

            <!-- 左侧：状态值控制 -->
            <Border Grid.Column="0" Background="#1a1a3e" CornerRadius="8" Padding="15"
                    Margin="0,0,5,0">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel>
                        <TextBlock Text="📊 状态值控制" FontSize="14" FontWeight="Bold"
                                   Foreground="White" Margin="0,0,0,15"/>

                        <!-- 时间滑块 -->
                        <StackPanel Margin="0,0,0,15">
                            <DockPanel>
                                <TextBlock Text="⏰ 时间" Foreground="White" Width="60"/>
                                <TextBlock x:Name="HourValue" Text="9.0" Foreground="#FFD700"
                                           HorizontalAlignment="Right"/>
                            </DockPanel>
                            <Slider x:Name="HourSlider" Minimum="0" Maximum="24" Value="9"
                                    IsSnapToTickEnabled="True" TickFrequency="1"
                                    ValueChanged="HourSlider_ValueChanged"/>
                        </StackPanel>

                        <!-- 精力滑块 -->
                        <StackPanel Margin="0,0,0,15">
                            <DockPanel>
                                <TextBlock Text="⚡ 精力" Foreground="White" Width="60"/>
                                <TextBlock x:Name="EnergyValue" Text="100" Foreground="#4CAF50"
                                           HorizontalAlignment="Right"/>
                            </DockPanel>
                            <Slider x:Name="EnergySlider" Minimum="0" Maximum="100" Value="100"
                                    ValueChanged="EnergySlider_ValueChanged"/>
                        </StackPanel>

                        <!-- 饥饿滑块 -->
                        <StackPanel Margin="0,0,0,15">
                            <DockPanel>
                                <TextBlock Text="🍽️ 饥饿" Foreground="White" Width="60"/>
                                <TextBlock x:Name="HungerValue" Text="0" Foreground="#FF5722"
                                           HorizontalAlignment="Right"/>
                            </DockPanel>
                            <Slider x:Name="HungerSlider" Minimum="0" Maximum="100" Value="0"
                                    ValueChanged="HungerSlider_ValueChanged"/>
                        </StackPanel>

                        <!-- 压力滑块 -->
                        <StackPanel Margin="0,0,0,15">
                            <DockPanel>
                                <TextBlock Text="💢 压力" Foreground="White" Width="60"/>
                                <TextBlock x:Name="StressValue" Text="0" Foreground="#E91E63"
                                           HorizontalAlignment="Right"/>
                            </DockPanel>
                            <Slider x:Name="StressSlider" Minimum="0" Maximum="100" Value="0"
                                    ValueChanged="StressSlider_ValueChanged"/>
                        </StackPanel>

                        <!-- 工作强度滑块（模糊输出） -->
                        <StackPanel Margin="0,0,0,15">
                            <DockPanel>
                                <TextBlock Text="💼 工作强度" Foreground="White" Width="60"/>
                                <TextBlock x:Name="WorkIntensityValue" Text="0.5" Foreground="#2196F3"
                                           HorizontalAlignment="Right"/>
                            </DockPanel>
                            <Slider x:Name="WorkIntensitySlider" Minimum="0" Maximum="1"
                                    Value="0.5" IsEnabled="False"/>
                        </StackPanel>

                        <!-- 老板在场开关 -->
                        <DockPanel Margin="0,0,0,20">
                            <TextBlock Text="👀 老板在场" Foreground="White" VerticalAlignment="Center"/>
                            <CheckBox x:Name="BossNearbyCheck" IsChecked="False"
                                      VerticalAlignment="Center" HorizontalAlignment="Right"
                                      Checked="BossNearbyCheck_Checked"
                                      Unchecked="BossNearbyCheck_Checked"/>
                        </DockPanel>

                        <!-- 快捷场景按钮 -->
                        <TextBlock Text="🎬 快捷场景" FontSize="14" FontWeight="Bold"
                                   Foreground="White" Margin="0,10,0,10"/>
                        <Button Content="😴 精力不足" Background="#3F51B5" Foreground="White"
                                Padding="10,5" Margin="0,0,0,5" Click="SceneLowEnergy_Click"/>
                        <Button Content="🍔 饥饿状态" Background="#FF5722" Foreground="White"
                                Padding="10,5" Margin="0,0,0,5" Click="SceneHungry_Click"/>
                        <Button Content="😫 高压状态" Background="#E91E63" Foreground="White"
                                Padding="10,5" Margin="0,0,0,5" Click="SceneHighStress_Click"/>
                        <Button Content="🌆 下班时间" Background="#9C27B0" Foreground="White"
                                Padding="10,5" Margin="0,0,0,5" Click="SceneOffWork_Click"/>
                        <Button Content="🎉 周末模式" Background="#FF9800" Foreground="White"
                                Padding="10,5" Margin="0,0,0,5" Click="SceneWeekend_Click"/>
                        <Button Content="📝 报告任务" Background="#00BCD4" Foreground="White"
                                Padding="10,5" Click="SceneReport_Click"/>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- 中间：状态机和行为树可视化 -->
            <Grid Grid.Column="1" Margin="5,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- FSM 状态可视化 -->
                <Border Grid.Row="0" Background="#1a1a3e" CornerRadius="8" Padding="15"
                        Margin="0,0,0,5">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="🔄 FSM 状态机" FontSize="14" FontWeight="Bold"
                                   Foreground="White" Margin="0,0,0,10"/>
                        <Canvas x:Name="FsmCanvas" Grid.Row="1" Background="#0d0d1a" Height="280">
                            <!-- 横向流程线 -->
                            <Line X1="95" Y1="75" X2="155" Y2="75" Stroke="#555" StrokeThickness="2"/>
                            <Line X1="245" Y1="75" X2="260" Y2="75" Stroke="#555" StrokeThickness="2"/>
                            <Polyline Points="305,75 305,50 200,50 200,190" Stroke="#555" StrokeThickness="2"/>

                            <!-- 竖向分支线 -->
                            <Line X1="95" Y1="120" X2="95" Y2="190" Stroke="#555" StrokeThickness="2"/>
                            <Polyline Points="95,235 155,235" Stroke="#555" StrokeThickness="2"/>
                            <Line X1="245" Y1="235" X2="260" Y2="235" Stroke="#555" StrokeThickness="2"/>

                            <!-- 标签 -->
                            <TextBlock Canvas.Left="115" Canvas.Top="58" Foreground="#666"
                                       Text="9:00" FontSize="10"/>
                            <TextBlock Canvas.Left="265" Canvas.Top="58" Foreground="#666"
                                       Text="17:00" FontSize="10"/>
                            <TextBlock Canvas.Left="195" Canvas.Top="190" Foreground="#666"
                                       Text="23:00" FontSize="10"/>
                            <TextBlock Canvas.Left="60" Canvas.Top="145" Foreground="#666"
                                       Text="周末" FontSize="10"/>

                            <!-- 早上 -->
                            <Ellipse x:Name="StateMorning" Width="90" Height="90"
                                     Canvas.Left="50" Canvas.Top="30"
                                     Fill="#FF9800" Stroke="#FFB74D" StrokeThickness="3"
                                     Opacity="0.5"/>
                            <TextBlock Canvas.Left="75" Canvas.Top="62" Foreground="White"
                                       Text="🌅 早上" FontWeight="Bold" FontSize="12"/>

                            <!-- 工作 -->
                            <Ellipse x:Name="StateWorking" Width="90" Height="90"
                                     Canvas.Left="155" Canvas.Top="30"
                                     Fill="#3F51B5" Stroke="#7986CB" StrokeThickness="3"
                                     Opacity="0.5"/>
                            <TextBlock Canvas.Left="180" Canvas.Top="62" Foreground="White"
                                       Text="💼 工作" FontWeight="Bold" FontSize="12"/>

                            <!-- 晚间 -->
                            <Ellipse x:Name="StateEvening" Width="90" Height="90"
                                     Canvas.Left="260" Canvas.Top="30"
                                     Fill="#4CAF50" Stroke="#81C784" StrokeThickness="3"
                                     Opacity="0.5"/>
                            <TextBlock Canvas.Left="283" Canvas.Top="62" Foreground="White"
                                       Text="🌆 晚间" FontWeight="Bold" FontSize="12"/>

                            <!-- 睡觉 -->
                            <Ellipse x:Name="StateSleeping" Width="90" Height="90"
                                     Canvas.Left="155" Canvas.Top="190"
                                     Fill="#673AB7" Stroke="#9575CD" StrokeThickness="3"
                                     Opacity="0.5"/>
                            <TextBlock Canvas.Left="177" Canvas.Top="222" Foreground="White"
                                       Text="😴 睡觉" FontWeight="Bold" FontSize="12"/>

                            <!-- 周末 -->
                            <Ellipse x:Name="StateWeekend" Width="90" Height="90"
                                     Canvas.Left="50" Canvas.Top="190"
                                     Fill="#E91E63" Stroke="#F06292" StrokeThickness="3"
                                     Opacity="0.5"/>
                            <TextBlock Canvas.Left="73" Canvas.Top="222" Foreground="White"
                                       Text="🎉 周末" FontWeight="Bold" FontSize="12"/>
                        </Canvas>
                    </Grid>
                </Border>

                <!-- 行为树节点激活 -->
                <Border Grid.Row="1" Background="#1a1a3e" CornerRadius="8" Padding="15"
                        Margin="0,5,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <DockPanel Grid.Row="0">
                            <TextBlock Text="🌳 行为树节点激活" FontSize="14" FontWeight="Bold"
                                       Foreground="White" Margin="0,0,0,10"/>
                            <TextBlock x:Name="CurrentBtName" Text="WorkBehavior"
                                       Foreground="#00BCD4" Margin="10,0,0,0"
                                       VerticalAlignment="Center"/>
                        </DockPanel>
                        <ScrollViewer Grid.Row="1" Background="#0d0d1a">
                            <StackPanel x:Name="BtNodesPanel" Margin="5">
                                <!-- 节点将动态添加 -->
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>

            <!-- 右侧：效用系统和 GOAP -->
            <Grid Grid.Column="2" Margin="5,0,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 效用系统得分 -->
                <Border Grid.Row="0" Background="#1a1a3e" CornerRadius="8" Padding="15"
                        Margin="0,0,0,5">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="⚖️ 效用系统得分" FontSize="14" FontWeight="Bold"
                                   Foreground="White" Margin="0,0,0,10"/>
                        <ScrollViewer Grid.Row="1" Background="#0d0d1a">
                            <StackPanel x:Name="UtilityPanel" Margin="5">
                                <!-- 得分条将动态添加 -->
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- GOAP 计划可视化 -->
                <Border Grid.Row="1" Background="#1a1a3e" CornerRadius="8" Padding="15"
                        Margin="0,5,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock Text="📋 GOAP 计划" FontSize="14" FontWeight="Bold"
                                   Foreground="White" Margin="0,0,0,10"/>
                        <ScrollViewer Grid.Row="1" Background="#0d0d1a">
                            <StackPanel x:Name="GoapPanel" Margin="5">
                                <!-- 计划步骤将动态添加 -->
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- 底部：实时状态图 -->
        <Border Grid.Row="2" Background="#1a1a3e" CornerRadius="8" Padding="15"
                Margin="0,10,0,0" Height="200">
            <ScottPlot:WpfPlot x:Name="StateChart"/>
        </Border>
    </Grid>
</UserControl>
