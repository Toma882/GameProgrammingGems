<Window x:Class="GPGems.DemoApp.Graphics.QuadtreeDemoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="🟦 四叉树空间分割 - Game Programming Gems"
        Height="800" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#0f0f23">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="100"/>
        </Grid.RowDefinitions>

        <!-- 📖 顶部：算法说明区 -->
        <Border Grid.Row="0" Background="#1a1a2e" Padding="15">
            <StackPanel Orientation="Horizontal">
                <StackPanel>
                    <TextBlock Text="🟦 四叉树空间分割" FontSize="18" Foreground="White" FontWeight="Bold"/>
                    <TextBlock Text="GPG 1 - Polygonal Chapter | 2D网格分割 + 高度场LOD简化" FontSize="12" Foreground="#a0a0a0" Margin="0 3"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="50 0 0 0" VerticalAlignment="Center">
                    <Border Background="#16213e" Padding="10 5" CornerRadius="4" Margin="0 0 10 0">
                        <TextBlock x:Name="NodeCountText" Text="节点数: 0" Foreground="#4ecca3" FontSize="12"/>
                    </Border>
                    <Border Background="#16213e" Padding="10 5" CornerRadius="4" Margin="0 0 10 0">
                        <TextBlock x:Name="PointCountText" Text="点数: 0" Foreground="#4ecca3" FontSize="12"/>
                    </Border>
                    <Border Background="#16213e" Padding="10 5" CornerRadius="4">
                        <TextBlock x:Name="DepthText" Text="最大深度: 0" Foreground="#4ecca3" FontSize="12"/>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="250"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="250"/>
            </Grid.ColumnDefinitions>

            <!-- ⚙️ 左侧：参数调节区 -->
            <Border Grid.Column="0" Background="#1a1a2e" Margin="5" Padding="15" CornerRadius="8">
                <ScrollViewer>
                    <StackPanel>
                        <TextBlock Text="⚙️ 参数调节" FontSize="14" Foreground="White" FontWeight="Bold" Margin="0 0 0 15"/>

                        <!-- 最大深度 -->
                        <TextBlock Text="最大深度" Foreground="#a0a0a0" FontSize="11" Margin="0 10 0 3"/>
                        <Slider x:Name="MaxDepthSlider" Minimum="2" Maximum="10" Value="6"
                                TickFrequency="1" IsSnapToTickEnabled="True"
                                Foreground="#4ecca3"/>
                        <TextBlock x:Name="MaxDepthValue" Text="6" Foreground="White" FontSize="10" HorizontalAlignment="Right"/>

                        <!-- 每节点最大元素数 -->
                        <TextBlock Text="每节点最大元素数" Foreground="#a0a0a0" FontSize="11" Margin="0 10 0 3"/>
                        <Slider x:Name="MaxElementsSlider" Minimum="2" Maximum="16" Value="4"
                                TickFrequency="1" IsSnapToTickEnabled="True"
                                Foreground="#4ecca3"/>
                        <TextBlock x:Name="MaxElementsValue" Text="4" Foreground="White" FontSize="10" HorizontalAlignment="Right"/>

                        <!-- 点数量 -->
                        <TextBlock Text="随机点数量" Foreground="#a0a0a0" FontSize="11" Margin="0 10 0 3"/>
                        <Slider x:Name="PointCountSlider" Minimum="100" Maximum="5000" Value="1000"
                                TickFrequency="100" IsSnapToTickEnabled="True"
                                Foreground="#4ecca3"/>
                        <TextBlock x:Name="PointCountValue" Text="1000" Foreground="White" FontSize="10" HorizontalAlignment="Right"/>

                        <Button x:Name="RegenerateButton" Content="🔄 重新生成点云"
                                Background="#4ecca3" Foreground="White" FontWeight="Bold"
                                Padding="10" Margin="0 20 0 5" Click="RegenerateButton_Click"/>

                        <Button x:Name="StepBuildButton" Content="▶ 分步构建"
                                Background="#e94560" Foreground="White" FontWeight="Bold"
                                Padding="10" Margin="0 5" Click="StepBuildButton_Click"/>

                        <CheckBox x:Name="ShowDepthColorsCheck" Content="按深度着色"
                                  IsChecked="True" Foreground="White" Margin="0 15 0 5"/>

                        <CheckBox x:Name="ShowBoundsCheck" Content="显示边界"
                                  IsChecked="True" Foreground="White" Margin="0 5"/>

                        <!-- 预设方案 -->
                        <TextBlock Text="📋 预设方案" Foreground="#a0a0a0" FontSize="11" Margin="0 20 0 10"/>

                        <Button Content="均衡模式" Background="#16213e" Foreground="White"
                                Padding="8" Margin="0 2" Click="PresetBalanced_Click"/>

                        <Button Content="高性能（少节点）" Background="#16213e" Foreground="White"
                                Padding="8" Margin="0 2" Click="PresetHighPerformance_Click"/>

                        <Button Content="高质量（细分割）" Background="#16213e" Foreground="White"
                                Padding="8" Margin="0 2" Click="PresetHighQuality_Click"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- 🖼️ 中央：主可视化区 -->
            <Border Grid.Column="1" Background="#0a0a1a" Margin="5 5 5 0" CornerRadius="8">
                <Canvas x:Name="DrawCanvas" Background="Transparent"
                        MouseMove="DrawCanvas_MouseMove"
                        MouseDown="DrawCanvas_MouseDown"/>
            </Border>

            <!-- 📊 右侧：性能监控区 -->
            <Border Grid.Column="2" Background="#1a1a2e" Margin="5" Padding="15" CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="📊 性能监控" FontSize="14" Foreground="White" FontWeight="Bold" Margin="0 0 0 15"/>

                    <TextBlock Text="构建耗时" Foreground="#a0a0a0" FontSize="11" Margin="0 10 0 3"/>
                    <TextBlock x:Name="BuildTimeText" Text="0 ms" Foreground="#e94560" FontSize="20" FontWeight="Bold"/>

                    <TextBlock Text="查询耗时" Foreground="#a0a0a0" FontSize="11" Margin="0 15 0 3"/>
                    <TextBlock x:Name="QueryTimeText" Text="0 ms" Foreground="#4ecca3" FontSize="20" FontWeight="Bold"/>

                    <TextBlock Text="范围查询结果数" Foreground="#a0a0a0" FontSize="11" Margin="0 15 0 3"/>
                    <TextBlock x:Name="QueryResultText" Text="0" Foreground="#f39c12" FontSize="20" FontWeight="Bold"/>

                    <Separator Background="#333" Margin="0 20"/>

                    <TextBlock Text="💡 操作提示" FontSize="12" Foreground="#a0a0a0" Margin="0 0 0 10"/>
                    <TextBlock Text="鼠标移动: 范围查询" Foreground="#666" FontSize="10" Margin="0 2"/>
                    <TextBlock Text="点击: 最近邻搜索" Foreground="#666" FontSize="10" Margin="0 2"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- 📝 底部：日志输出区 -->
        <Border Grid.Row="2" Background="#0a0a1a" Margin="5 0 5 5" Padding="10" CornerRadius="8">
            <ScrollViewer>
                <TextBlock x:Name="LogText" Foreground="#4ecca3" FontFamily="Consolas" FontSize="11"/>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
