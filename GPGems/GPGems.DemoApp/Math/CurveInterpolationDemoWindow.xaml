<Window x:Class="GPGems.DemoApp.Math.CurveInterpolationDemoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="📈 曲线插值对比 - Game Programming Gems"
        Height="800" Width="1400"
        WindowStartupLocation="CenterScreen"
        Background="#0f0f23">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="100"/>
        </Grid.RowDefinitions>

        <!-- 📖 顶部：算法说明区 -->
        <Border Grid.Row="0" Background="#1a1a2e" Padding="15">
            <StackPanel Orientation="Horizontal">
                <StackPanel>
                    <TextBlock Text="📈 曲线插值对比" FontSize="18" Foreground="White" FontWeight="Bold"/>
                    <TextBlock Text="Bezier / Hermite / Catmull-Rom / TCB 样条 - 游戏动画与路径平滑核心" FontSize="12" Foreground="#a0a0a0" Margin="0 3"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="50 0 0 0" VerticalAlignment="Center">
                    <Border Background="#16213e" Padding="10 5" CornerRadius="4" Margin="0 0 10 0">
                        <TextBlock x:Name="PointCountText" Text="控制点: 4" Foreground="#f39c12" FontSize="12"/>
                    </Border>
                    <Border Background="#16213e" Padding="10 5" CornerRadius="4">
                        <TextBlock x:Name="CurveLengthText" Text="曲线长度: 0" Foreground="#4ecca3" FontSize="12"/>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="260"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="260"/>
            </Grid.ColumnDefinitions>

            <!-- ⚙️ 左侧：参数调节区 -->
            <Border Grid.Column="0" Background="#1a1a2e" Margin="5" Padding="15" CornerRadius="8">
                <ScrollViewer>
                    <StackPanel>
                        <TextBlock Text="⚙️ 曲线类型" FontSize="14" Foreground="White" FontWeight="Bold" Margin="0 0 0 15"/>

                        <RadioButton x:Name="TypeBezier" Content="三次 Bezier" Foreground="White" GroupName="CurveType"
                                     IsChecked="True" Margin="0 5" Checked="CurveTypeChanged"/>
                        <RadioButton x:Name="TypeHermite" Content="Hermite 埃尔米特" Foreground="White" GroupName="CurveType"
                                     Margin="0 5" Checked="CurveTypeChanged"/>
                        <RadioButton x:Name="TypeCatmullRom" Content="Catmull-Rom 样条" Foreground="White" GroupName="CurveType"
                                     Margin="0 5" Checked="CurveTypeChanged"/>
                        <RadioButton x:Name="TypeTCB" Content="TCB 张力/连续/偏移" Foreground="White" GroupName="CurveType"
                                     Margin="0 5" Checked="CurveTypeChanged"/>

                        <Separator Background="#333" Margin="0 15"/>

                        <TextBlock Text="🎛️ 参数调节" FontSize="14" Foreground="White" FontWeight="Bold" Margin="0 0 0 10"/>

                        <!-- TCB 参数 -->
                        <TextBlock x:Name="TensionLabel" Text="张力 Tension" Foreground="#a0a0a0" FontSize="11" Margin="0 10 0 3"/>
                        <Slider x:Name="TensionSlider" Minimum="-1" Maximum="1" Value="0" TickFrequency="0.1"
                                IsEnabled="False" Foreground="#e94560" ValueChanged="TCBParameterChanged"/>
                        <TextBlock x:Name="TensionValue" Text="0.00" Foreground="White" FontSize="10" HorizontalAlignment="Right"/>

                        <TextBlock x:Name="ContinuityLabel" Text="连续 Continuity" Foreground="#a0a0a0" FontSize="11" Margin="0 10 0 3"/>
                        <Slider x:Name="ContinuitySlider" Minimum="-1" Maximum="1" Value="0" TickFrequency="0.1"
                                IsEnabled="False" Foreground="#e94560" ValueChanged="TCBParameterChanged"/>
                        <TextBlock x:Name="ContinuityValue" Text="0.00" Foreground="White" FontSize="10" HorizontalAlignment="Right"/>

                        <TextBlock x:Name="BiasLabel" Text="偏移 Bias" Foreground="#a0a0a0" FontSize="11" Margin="0 10 0 3"/>
                        <Slider x:Name="BiasSlider" Minimum="-1" Maximum="1" Value="0" TickFrequency="0.1"
                                IsEnabled="False" Foreground="#e94560" ValueChanged="TCBParameterChanged"/>
                        <TextBlock x:Name="BiasValue" Text="0.00" Foreground="White" FontSize="10" HorizontalAlignment="Right"/>

                        <Separator Background="#333" Margin="0 15"/>

                        <TextBlock Text="显示选项" Foreground="#a0a0a0" FontSize="11" Margin="0 5 0 3"/>
                        <CheckBox x:Name="ShowControlPointsCheck" Content="显示控制点" IsChecked="True"
                                  Foreground="White" Margin="0 3" Checked="DisplayOptionChanged"/>
                        <CheckBox x:Name="ShowTangentsCheck" Content="显示切线方向" IsChecked="True"
                                  Foreground="White" Margin="0 3" Checked="DisplayOptionChanged"/>
                        <CheckBox x:Name="ShowVelocityCheck" Content="显示速度曲线" IsChecked="False"
                                  Foreground="White" Margin="0 3" Checked="DisplayOptionChanged"/>

                        <Separator Background="#333" Margin="0 15"/>

                        <Button x:Name="ResetButton" Content="↺ 重置控制点" Background="#e94560" Foreground="White"
                                FontWeight="Bold" Padding="10" Margin="0 5" Click="ResetButton_Click"/>

                        <Button x:Name="PlayAnimButton" Content="▶ 播放动画" Background="#4ecca3" Foreground="White"
                                FontWeight="Bold" Padding="10" Margin="0 5" Click="PlayAnimButton_Click"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>

            <!-- 🖼️ 中央：主可视化区 -->
            <Border Grid.Column="1" Background="#0a0a1a" Margin="5 5 5 0" CornerRadius="8">
                <Grid>
                    <Canvas x:Name="DrawCanvas" Background="Transparent"
                            MouseDown="DrawCanvas_MouseDown"
                            MouseMove="DrawCanvas_MouseMove"
                            MouseUp="DrawCanvas_MouseUp"/>

                    <!-- 移动粒子 -->
                    <Ellipse x:Name="MovingParticle" Width="16" Height="16" Visibility="Collapsed">
                        <Ellipse.Fill>
                            <RadialGradientBrush>
                                <GradientStop Color="#ff6b6b" Offset="0"/>
                                <GradientStop Color="#e94560" Offset="1"/>
                            </RadialGradientBrush>
                        </Ellipse.Fill>
                    </Ellipse>
                </Grid>
            </Border>

            <!-- 📊 右侧：信息区 -->
            <Border Grid.Column="2" Background="#1a1a2e" Margin="5" Padding="15" CornerRadius="8">
                <ScrollViewer>
                    <StackPanel>
                        <TextBlock Text="📚 算法说明" FontSize="14" Foreground="White" FontWeight="Bold" Margin="0 0 0 15"/>

                        <TextBlock x:Name="AlgorithmTitle" Text="三次 Bezier 曲线" FontSize="12" Foreground="#f39c12" FontWeight="Bold"/>
                        <TextBlock x:Name="AlgorithmDesc"
                                   Text="通过4个控制点定义平滑曲线。前两个和后两个控制点决定曲线的起止切线方向。"
                                   FontSize="11" Foreground="#a0a0a0" Margin="0 5 0 15"
                                   TextWrapping="Wrap"/>

                        <Separator Background="#333" Margin="0 10"/>

                        <TextBlock Text="💡 操作提示" FontSize="12" Foreground="#a0a0a0" Margin="0 10 0 10"/>
                        <TextBlock Text="• 拖拽控制点调整曲线" Foreground="#666" FontSize="10" Margin="0 2"/>
                        <TextBlock Text="• 点击空白添加控制点" Foreground="#666" FontSize="10" Margin="0 2"/>
                        <TextBlock Text="• 右键删除控制点" Foreground="#666" FontSize="10" Margin="0 2"/>
                        <TextBlock Text="• 点击播放查看动画效果" Foreground="#666" FontSize="10" Margin="0 2"/>

                        <Separator Background="#333" Margin="0 15"/>

                        <TextBlock Text="📐 曲线统计" FontSize="12" Foreground="White" FontWeight="Bold" Margin="0 5"/>
                        <TextBlock x:Name="StatsPoints" Text="控制点数量: 4" Foreground="#4ecca3" FontSize="11" Margin="0 2"/>
                        <TextBlock x:Name="StatsLength" Text="曲线长度: 0 px" Foreground="#4ecca3" FontSize="11" Margin="0 2"/>
                        <TextBlock x:Name="StatsCurvature" Text="最大曲率: 0" Foreground="#4ecca3" FontSize="11" Margin="0 2"/>
                    </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- 📝 底部：日志输出区 -->
        <Border Grid.Row="2" Background="#0a0a1a" Margin="5 0 5 5" Padding="10" CornerRadius="8">
            <ScrollViewer>
                <TextBlock x:Name="LogText" Foreground="#4ecca3" FontFamily="Consolas" FontSize="11"/>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
