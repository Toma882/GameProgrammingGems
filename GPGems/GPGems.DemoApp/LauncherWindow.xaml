<Window x:Class="GPGems.DemoApp.LauncherWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Game Programming Gems - C# 演示" Height="500" Width="700"
        WindowStartupLocation="CenterScreen"
        Background="#0f0f23">

    <Window.Resources>
        <Style x:Key="CardButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <Border Grid.Row="0" Padding="30" Background="#1a1a2e">
            <StackPanel>
                <TextBlock Text="🎮 Game Programming Gems" FontSize="24" Foreground="White" FontWeight="Bold"/>
                <TextBlock Text="经典游戏算法的 C# 现代化实现" FontSize="14" Foreground="#a0a0a0" Margin="0 5 0 0"/>
            </StackPanel>
        </Border>

        <!-- 算法卡片列表 -->
        <ScrollViewer Grid.Row="1" Padding="20">
            <WrapPanel Orientation="Horizontal">

                <!-- Boids 群体行为 -->
                <Border Width="280" Height="200" Margin="10"
                        Background="#16213e" CornerRadius="10"
                        BorderBrush="#e94560" BorderThickness="2">
                    <Grid>
                        <Button Style="{StaticResource CardButtonStyle}" Click="OpenBoidsDemo"/>
                        <StackPanel Margin="20" VerticalAlignment="Center">
                            <TextBlock Text="🐦" FontSize="48" HorizontalAlignment="Center" Margin="0 0 0 10"/>
                            <TextBlock Text="Boids 群体行为" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="Reynolds 三大规则" FontSize="12" Foreground="#a0a0a0" HorizontalAlignment="Center" Margin="0 5"/>
                            <TextBlock Text="分离 · 对齐 · 凝聚" FontSize="11" Foreground="#808080" HorizontalAlignment="Center" Margin="0 5"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 博弈树搜索 -->
                <Border Width="280" Height="200" Margin="10"
                        Background="#16213e" CornerRadius="10"
                        BorderBrush="#4ecca3" BorderThickness="2">
                    <Grid>
                        <Button Style="{StaticResource CardButtonStyle}" Click="OpenGameTreeDemo"/>
                        <StackPanel Margin="20" VerticalAlignment="Center">
                            <TextBlock Text="🌳" FontSize="48" HorizontalAlignment="Center" Margin="0 0 0 10"/>
                            <TextBlock Text="博弈树搜索" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="Minimax + Alpha-Beta 剪枝" FontSize="12" Foreground="#a0a0a0" HorizontalAlignment="Center" Margin="0 5"/>
                            <TextBlock Text="井字棋 AI 演示" FontSize="11" Foreground="#808080" HorizontalAlignment="Center" Margin="0 5"/>
                        </StackPanel>
                    </Grid>
                </Border>

    

                <!-- A* 寻路 -->
                <Border Width="280" Height="200" Margin="10"
                        Background="#16213e" CornerRadius="10"
                        BorderBrush="#4361ee" BorderThickness="2">
                    <Grid>
                        <Button Style="{StaticResource CardButtonStyle}" Click="OpenAStarDemo"/>
                        <StackPanel Margin="20" VerticalAlignment="Center">
                            <TextBlock Text="🗺️" FontSize="48" HorizontalAlignment="Center" Margin="0 0 0 10"/>
                            <TextBlock Text="寻路算法对比" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="A* / Dijkstra / BFS / DFS" FontSize="12" Foreground="#a0a0a0" HorizontalAlignment="Center" Margin="0 5"/>
                            <TextBlock Text="同地图多算法对比" FontSize="11" Foreground="#808080" HorizontalAlignment="Center" Margin="0 5"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Steering 定向行为 -->
                <Border Width="280" Height="200" Margin="10"
                        Background="#16213e" CornerRadius="10"
                        BorderBrush="#9b59b6" BorderThickness="2">
                    <Grid>
                        <Button Style="{StaticResource CardButtonStyle}" Click="OpenSteeringDemo"/>
                        <StackPanel Margin="20" VerticalAlignment="Center">
                            <TextBlock Text="🎯" FontSize="48" HorizontalAlignment="Center" Margin="0 0 0 10"/>
                            <TextBlock Text="Steering 定向行为" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="Seek / Flee / Arrive / Wander" FontSize="12" Foreground="#a0a0a0" HorizontalAlignment="Center" Margin="0 5"/>
                            <TextBlock Text="Pursue / Evade 轨迹对比" FontSize="11" Foreground="#808080" HorizontalAlignment="Center" Margin="0 5"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 庄园模拟 -->
                <Border Width="280" Height="200" Margin="10"
                        Background="#16213e" CornerRadius="10"
                        BorderBrush="#f39c12" BorderThickness="2">
                    <Grid>
                        <Button Style="{StaticResource CardButtonStyle}" Click="OpenManorDemo"/>
                        <StackPanel Margin="20" VerticalAlignment="Center">
                            <TextBlock Text="🏰" FontSize="48" HorizontalAlignment="Center" Margin="0 0 0 10"/>
                            <TextBlock Text="庄园模拟" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="流场/ORCA/Boids/社会力模型" FontSize="12" Foreground="#a0a0a0" HorizontalAlignment="Center" Margin="0 5"/>
                            <TextBlock Text="客流·动物·员工·疏散" FontSize="11" Foreground="#808080" HorizontalAlignment="Center" Margin="0 5"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 融合决策系统 -->
                <Border Width="280" Height="200" Margin="10"
                        Background="#16213e" CornerRadius="10"
                        BorderBrush="#f39c12" BorderThickness="2">
                    <Grid>
                        <Button Style="{StaticResource CardButtonStyle}" Click="OpenDecisionSystemDemo"/>
                        <StackPanel Margin="20" VerticalAlignment="Center">
                            <TextBlock Text="🧠" FontSize="48" HorizontalAlignment="Center" Margin="0 0 0 10"/>
                            <TextBlock Text="NPC 日常生活" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="FSM + 模糊 + 效用 + GOAP" FontSize="12" Foreground="#a0a0a0" HorizontalAlignment="Center" Margin="0 5"/>
                            <TextBlock Text="起床/通勤/工作/摸鱼/睡觉" FontSize="11" Foreground="#808080" HorizontalAlignment="Center" Margin="0 5"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 四叉树空间分割 -->
                <Border Width="280" Height="200" Margin="10"
                        Background="#16213e" CornerRadius="10"
                        BorderBrush="#4ecdc4" BorderThickness="2">
                    <Grid>
                        <Button Style="{StaticResource CardButtonStyle}" Click="OpenQuadtreeDemo"/>
                        <StackPanel Margin="20" VerticalAlignment="Center">
                            <TextBlock Text="🟦" FontSize="48" HorizontalAlignment="Center" Margin="0 0 0 10"/>
                            <TextBlock Text="四叉树空间分割" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="2D 网格 + 高度场 LOD" FontSize="12" Foreground="#a0a0a0" HorizontalAlignment="Center" Margin="0 5"/>
                            <TextBlock Text="范围/最近邻查询" FontSize="11" Foreground="#808080" HorizontalAlignment="Center" Margin="0 5"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 八叉树 3D 空间分割 -->
                <Border Width="280" Height="200" Margin="10"
                        Background="#16213e" CornerRadius="10"
                        BorderBrush="#9b59b6" BorderThickness="2">
                    <Grid>
                        <Button Style="{StaticResource CardButtonStyle}" Click="OpenOctreeDemo"/>
                        <StackPanel Margin="20" VerticalAlignment="Center">
                            <TextBlock Text="📦" FontSize="48" HorizontalAlignment="Center" Margin="0 0 0 10"/>
                            <TextBlock Text="八叉树 3D 空间分割" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="四视图 3D 投影" FontSize="12" Foreground="#a0a0a0" HorizontalAlignment="Center" Margin="0 5"/>
                            <TextBlock Text="范围/射线查询" FontSize="11" Foreground="#808080" HorizontalAlignment="Center" Margin="0 5"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- KD 树 k-近邻搜索 -->
                <Border Width="280" Height="200" Margin="10"
                        Background="#16213e" CornerRadius="10"
                        BorderBrush="#f1c40f" BorderThickness="2">
                    <Grid>
                        <Button Style="{StaticResource CardButtonStyle}" Click="OpenKDTreeDemo"/>
                        <StackPanel Margin="20" VerticalAlignment="Center">
                            <TextBlock Text="🌲" FontSize="48" HorizontalAlignment="Center" Margin="0 0 0 10"/>
                            <TextBlock Text="KD 树 k-近邻搜索" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="中位数分割 + 回溯剪枝" FontSize="12" Foreground="#a0a0a0" HorizontalAlignment="Center" Margin="0 5"/>
                            <TextBlock Text="按轴着色 + 搜索路径可视化" FontSize="11" Foreground="#808080" HorizontalAlignment="Center" Margin="0 5"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- k-NN 回归模型可视化 -->
                <Border Width="280" Height="200" Margin="10"
                        Background="#16213e" CornerRadius="10"
                        BorderBrush="#2ecc71" BorderThickness="2">
                    <Grid>
                        <Button Style="{StaticResource CardButtonStyle}" Click="OpenKnnRegressionDemo"/>
                        <StackPanel Margin="20" VerticalAlignment="Center">
                            <TextBlock Text="📈" FontSize="48" HorizontalAlignment="Center" Margin="0 0 0 10"/>
                            <TextBlock Text="k-NN 回归模型" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="加权平均 + 曲线拟合" FontSize="12" Foreground="#a0a0a0" HorizontalAlignment="Center" Margin="0 5"/>
                            <TextBlock Text="可调k值 + 距离度量 + MSE" FontSize="11" Foreground="#808080" HorizontalAlignment="Center" Margin="0 5"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 最近邻算法性能对比 -->
                <Border Width="280" Height="200" Margin="10"
                        Background="#16213e" CornerRadius="10"
                        BorderBrush="#9b59b6" BorderThickness="2">
                    <Grid>
                        <Button Style="{StaticResource CardButtonStyle}" Click="OpenNearestNeighborBenchmark"/>
                        <StackPanel Margin="20" VerticalAlignment="Center">
                            <TextBlock Text="⚡" FontSize="48" HorizontalAlignment="Center" Margin="0 0 0 10"/>
                            <TextBlock Text="最近邻算法基准测试" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="暴力 vs KD树 vs Ball树 vs LSH" FontSize="12" Foreground="#a0a0a0" HorizontalAlignment="Center" Margin="0 5"/>
                            <TextBlock Text="维度/规模扫描动画" FontSize="11" Foreground="#808080" HorizontalAlignment="Center" Margin="0 5"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 最近邻搜索多算法对比演示 -->
                <Border Width="280" Height="200" Margin="10"
                        Background="#16213e" CornerRadius="10"
                        BorderBrush="#28a745" BorderThickness="2">
                    <Grid>
                        <Button Style="{StaticResource CardButtonStyle}" Click="OpenNearestNeighborSearchDemo"/>
                        <StackPanel Margin="20" VerticalAlignment="Center">
                            <TextBlock Text="🔍" FontSize="48" HorizontalAlignment="Center" Margin="0 0 0 10"/>
                            <TextBlock Text="最近邻搜索多算法对比" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="点击画布设置查询点" FontSize="12" Foreground="#a0a0a0" HorizontalAlignment="Center" Margin="0 5"/>
                            <TextBlock Text="实时精度/性能对比" FontSize="11" Foreground="#808080" HorizontalAlignment="Center" Margin="0 5"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 地形生成算法三剑合一 -->
                <Border Width="280" Height="200" Margin="10"
                        Background="#16213e" CornerRadius="10"
                        BorderBrush="#e67e22" BorderThickness="2">
                    <Grid>
                        <Button Style="{StaticResource CardButtonStyle}" Click="OpenTerrainGenerationDemo"/>
                        <StackPanel Margin="20" VerticalAlignment="Center">
                            <TextBlock Text="🏔️" FontSize="48" HorizontalAlignment="Center" Margin="0 0 0 10"/>
                            <TextBlock Text="地形生成算法三剑合一" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="断层 · 分形 · 粒子侵蚀" FontSize="12" Foreground="#a0a0a0" HorizontalAlignment="Center" Margin="0 5"/>
                            <TextBlock Text="三画布实时对比" FontSize="11" Foreground="#808080" HorizontalAlignment="Center" Margin="0 5"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- BSP 树空间分割 -->
                <Border Width="280" Height="200" Margin="10"
                        Background="#16213e" CornerRadius="10"
                        BorderBrush="#e74c3c" BorderThickness="2">
                    <Grid>
                        <Button Style="{StaticResource CardButtonStyle}" Click="OpenBSPTreeDemo"/>
                        <StackPanel Margin="20" VerticalAlignment="Center">
                            <TextBlock Text="🌳" FontSize="48" HorizontalAlignment="Center" Margin="0 0 0 10"/>
                            <TextBlock Text="BSP 树空间分割" FontSize="18" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="多边形分割 · 画家算法" FontSize="12" Foreground="#a0a0a0" HorizontalAlignment="Center" Margin="0 5"/>
                            <TextBlock Text="射线检测 · Portal可见性" FontSize="11" Foreground="#808080" HorizontalAlignment="Center" Margin="0 5"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 多分辨率栅格 Chunked LOD -->
                <Border Width="280" Height="200" Margin="10"
                        Background="#16213e" CornerRadius="10"
                        BorderBrush="#3498db" BorderThickness="2">
                    <Grid>
                        <Button Style="{StaticResource CardButtonStyle}" Click="OpenMultiresGridDemo"/>
                        <StackPanel Margin="20" VerticalAlignment="Center">
                            <TextBlock Text="📊" FontSize="48" HorizontalAlignment="Center" Margin="0 0 0 10"/>
                            <TextBlock Text="多分辨率栅格 Chunked LOD" FontSize="16" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="块式分块 · 视距LOD切换" FontSize="12" Foreground="#a0a0a0" HorizontalAlignment="Center" Margin="0 5"/>
                            <TextBlock Text="深度/距离双驱动" FontSize="11" Foreground="#808080" HorizontalAlignment="Center" Margin="0 5"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 渐进网格 Progressive Mesh -->
                <Border Width="280" Height="200" Margin="10"
                        Background="#16213e" CornerRadius="10"
                        BorderBrush="#9b59b6" BorderThickness="2">
                    <Grid>
                        <Button Style="{StaticResource CardButtonStyle}" Click="OpenProgressiveMeshDemo"/>
                        <StackPanel Margin="20" VerticalAlignment="Center">
                            <TextBlock Text="⚡" FontSize="48" HorizontalAlignment="Center" Margin="0 0 0 10"/>
                            <TextBlock Text="渐进网格 Progressive Mesh" FontSize="16" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="边折叠 · 边分裂 · 误差计算" FontSize="12" Foreground="#a0a0a0" HorizontalAlignment="Center" Margin="0 5"/>
                            <TextBlock Text="曲率权重 · 边界保护" FontSize="11" Foreground="#808080" HorizontalAlignment="Center" Margin="0 5"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 连续LOD地形 CLOD Terrain -->
                <Border Width="280" Height="200" Margin="10"
                        Background="#16213e" CornerRadius="10"
                        BorderBrush="#1abc9c" BorderThickness="2">
                    <Grid>
                        <Button Style="{StaticResource CardButtonStyle}" Click="OpenCLODTerrainDemo"/>
                        <StackPanel Margin="20" VerticalAlignment="Center">
                            <TextBlock Text="🏔️" FontSize="48" HorizontalAlignment="Center" Margin="0 0 0 10"/>
                            <TextBlock Text="连续LOD地形 ROAM" FontSize="16" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="二叉三角剖分 · 自适应细化" FontSize="12" Foreground="#a0a0a0" HorizontalAlignment="Center" Margin="0 5"/>
                            <TextBlock Text="视点驱动 · 逐帧优化" FontSize="11" Foreground="#808080" HorizontalAlignment="Center" Margin="0 5"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 曲线插值对比 -->
                <Border Width="280" Height="200" Margin="10"
                        Background="#16213e" CornerRadius="10"
                        BorderBrush="#9b59b6" BorderThickness="2">
                    <Grid>
                        <Button Style="{StaticResource CardButtonStyle}" Click="OpenCurveInterpolationDemo"/>
                        <StackPanel Margin="20" VerticalAlignment="Center">
                            <TextBlock Text="📈" FontSize="48" HorizontalAlignment="Center" Margin="0 0 0 10"/>
                            <TextBlock Text="曲线插值对比" FontSize="16" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="Bezier / Hermite / Catmull-Rom" FontSize="12" Foreground="#a0a0a0" HorizontalAlignment="Center" Margin="0 5"/>
                            <TextBlock Text="TCB 样条 · 动画轨迹" FontSize="11" Foreground="#808080" HorizontalAlignment="Center" Margin="0 5"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- 噪声生成器 -->
                <Border Width="280" Height="200" Margin="10"
                        Background="#16213e" CornerRadius="10"
                        BorderBrush="#2ecc71" BorderThickness="2">
                    <Grid>
                        <Button Style="{StaticResource CardButtonStyle}" Click="OpenNoiseDemo"/>
                        <StackPanel Margin="20" VerticalAlignment="Center">
                            <TextBlock Text="🌫️" FontSize="48" HorizontalAlignment="Center" Margin="0 0 0 10"/>
                            <TextBlock Text="噪声生成器" FontSize="16" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="Perlin / Simplex 噪声" FontSize="12" Foreground="#a0a0a0" HorizontalAlignment="Center" Margin="0 5"/>
                            <TextBlock Text="分形叠加 · 程序化地形" FontSize="11" Foreground="#808080" HorizontalAlignment="Center" Margin="0 5"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- GJK 碰撞检测 -->
                <Border Width="280" Height="200" Margin="10"
                        Background="#16213e" CornerRadius="10"
                        BorderBrush="#e74c3c" BorderThickness="2">
                    <Grid>
                        <Button Style="{StaticResource CardButtonStyle}" Click="OpenGJKDemo"/>
                        <StackPanel Margin="20" VerticalAlignment="Center">
                            <TextBlock Text="⚡" FontSize="48" HorizontalAlignment="Center" Margin="0 0 0 10"/>
                            <TextBlock Text="GJK + EPA 碰撞检测" FontSize="16" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center"/>
                            <TextBlock Text="Minkowski 和 · Simplex 演化" FontSize="12" Foreground="#a0a0a0" HorizontalAlignment="Center" Margin="0 5"/>
                            <TextBlock Text="穿透深度 · 碰撞法向量" FontSize="11" Foreground="#808080" HorizontalAlignment="Center" Margin="0 5"/>
                        </StackPanel>
                    </Grid>
                </Border>

            </WrapPanel>
        </ScrollViewer>
    </Grid>
</Window>
